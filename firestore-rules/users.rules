// ==============================================================
// USERS (private)
// ==============================================================
//
// Responsibilities:
// - allow users to update their own ordinary profile fields;
// - block client-side changes to auth, privilege, billing, lifecycle,
//   and compliance fields;
// - allow initial creation only with safe defaults;
// - reserve administrative, financial, and compliance updates for trusted
//   backend code.
// ==============================================================

match /users/{userId} {

  function isAdminActor() {
    return isAdmin();
  }

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function affectedUserKeys() {
    return request.resource.data.diff(resource.data).affectedKeys();
  }

  function emailVerifiedMatchesToken() {
    return !hasField("emailVerified")
      || request.resource.data.emailVerified
        == (request.auth.token.email_verified == true);
  }

  function emailVerifiedSafeOnUpdate() {
    return !affectedUserKeys().hasAny(["emailVerified"])
      || request.resource.data.emailVerified
        == (request.auth.token.email_verified == true);
  }

  function selfChangingSensitiveKeys() {
    return affectedUserKeys().hasAny([
      "adultConsent",
      "acceptedTerms",
      "registrationFlowVersion",
      "initialAdultConsentRequired",
      "registrationCompletedAt",
      "ageReverification",
      "ageReverificationRestrictedAt",

      "role",
      "tier",
      "isSubscriber",
      "monthlyPayer",
      "subscriptionStatus",
      "subscriptionScope",
      "subscriptionExpires",
      "lastBillingCheckoutSessionId",
      "lastBillingTransactionId",
      "billingUpdatedAt",
      "currentSubscriptionId",
      "subscriptionStartedAt",
      "subscriptionEndsAt",
      "subscriptionCanceledAt",
      "billingCustomerId",
      "billingProvider",

      "roles",
      "permissions",
      "entitlements",

      "accountLocked",
      "accountStatus",
      "publicVisibility",
      "interactionBlocked",
      "loginAllowed",

      "suspended",
      "suspensionReason",
      "suspensionSource",
      "suspensionEndsAt",
      "suspendedAt",
      "suspendedAtMs",
      "suspendedBy",
      "unsuspendedAtMs",
      "unsuspendedBy",

      "deletionRequestedAt",
      "deletionRequestedBy",
      "deletionUndoUntil",
      "purgeAfter",

      "statusUpdatedAt",
      "statusUpdatedBy",
      "moderatedBy",
      "moderatedAt",
      "lastStatusChangeAt"
    ]);
  }

  function adminModerationOnly() {
    return affectedUserKeys().hasOnly([
      "accountLocked",
      "suspended",
      "suspensionReason",
      "suspendedAt",
      "accountStatus",
      "moderatedBy",
      "moderatedAt",
      "lastStatusChangeAt"
    ]);
  }

  function createDefaultsOk() {
    return request.resource.data.keys().hasAny(["uid"])
      && request.resource.data.uid == uid()

      && !hasField("adultConsent")
      && !hasField("ageReverification")
      && !hasField("ageReverificationRestrictedAt")
      && hasField("registrationFlowVersion")
      && request.resource.data.registrationFlowVersion == "v2"
      && hasField("initialAdultConsentRequired")
      && request.resource.data.initialAdultConsentRequired == true
      && hasField("registrationCompletedAt")
      && request.resource.data.registrationCompletedAt == null

      && (!hasField("role") || request.resource.data.role == "free")
      && (!hasField("tier") || request.resource.data.tier == "free")
      && (!hasField("isSubscriber") || request.resource.data.isSubscriber == false)
      && (!hasField("monthlyPayer") || request.resource.data.monthlyPayer == false)
      && (!hasField("subscriptionStatus")
        || request.resource.data.subscriptionStatus == "inactive")
      && (!hasField("subscriptionScope")
        || request.resource.data.subscriptionScope == null)
      && (!hasField("subscriptionExpires")
        || request.resource.data.subscriptionExpires == null)
      && (!hasField("lastBillingCheckoutSessionId")
        || request.resource.data.lastBillingCheckoutSessionId == null)
      && (!hasField("lastBillingTransactionId")
        || request.resource.data.lastBillingTransactionId == null)
      && (!hasField("billingUpdatedAt")
        || request.resource.data.billingUpdatedAt == null)

      && (!hasField("roles") || request.resource.data.roles == ["user"])
      && (!hasField("permissions") || request.resource.data.permissions == [])
      && (!hasField("entitlements") || request.resource.data.entitlements == [])

      && (!hasField("accountLocked") || request.resource.data.accountLocked == false)
      && (!hasField("accountStatus") || request.resource.data.accountStatus == "active")
      && (!hasField("publicVisibility")
        || request.resource.data.publicVisibility == "visible")
      && (!hasField("interactionBlocked")
        || request.resource.data.interactionBlocked == false)
      && (!hasField("loginAllowed") || request.resource.data.loginAllowed == true)
      && (!hasField("suspended") || request.resource.data.suspended == false)
      && (!hasField("suspensionReason")
        || request.resource.data.suspensionReason == null)
      && (!hasField("suspensionSource")
        || request.resource.data.suspensionSource == null)
      && (!hasField("suspensionEndsAt")
        || request.resource.data.suspensionEndsAt == null)
      && (!hasField("deletionRequestedAt")
        || request.resource.data.deletionRequestedAt == null)
      && (!hasField("deletionRequestedBy")
        || request.resource.data.deletionRequestedBy == null)
      && (!hasField("deletionUndoUntil")
        || request.resource.data.deletionUndoUntil == null)
      && (!hasField("purgeAfter") || request.resource.data.purgeAfter == null);
  }

  allow get: if isSelf(userId) || isAdminActor();
  allow list: if false;

  allow create: if isSelf(userId)
    && emailVerifiedMatchesToken()
    && createDefaultsOk();

  allow update: if
    (
      isSelf(userId)
      && !selfChangingSensitiveKeys()
      && emailVerifiedSafeOnUpdate()
    )
    || (
      isAdminActor()
      && adminModerationOnly()
    );

  allow delete: if false;
}