// ==============================================================
// USERS (private)
// ==============================================================
// - ordinary profile fields remain self-editable;
// - auth, privilege, billing, lifecycle and compliance fields are protected;
// - profileCompleted is a one-way, eligibility-checked registration transition;
// - new accounts are private and interaction-blocked until completion;
// - accepted terms start false and can only become true through trusted backend.
// ==============================================================

match /users/{userId} {

  function isAdminActor() {
    return isAdmin();
  }

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function affectedUserKeys() {
    return request.resource.data.diff(resource.data).affectedKeys();
  }

  function authEmailVerified() {
    return signedIn()
      && request.auth.token.keys().hasAny(["email_verified"])
      && request.auth.token.email_verified == true;
  }

  function emailVerifiedMatchesToken() {
    return !hasField("emailVerified")
      || request.resource.data.emailVerified == authEmailVerified();
  }

  function emailVerifiedSafeOnUpdate() {
    return !affectedUserKeys().hasAny(["emailVerified"])
      || request.resource.data.emailVerified == authEmailVerified();
  }

  function selfChangingSensitiveKeys() {
    return affectedUserKeys().hasAny([
      "adultConsent",
      "acceptedTerms",
      "registrationFlowVersion",
      "initialAdultConsentRequired",
      "registrationCompletedAt",
      "profileCompleted",
      "ageReverification",
      "ageReverificationRestrictedAt",

      "role",
      "tier",
      "isSubscriber",
      "monthlyPayer",
      "subscriptionStatus",
      "subscriptionScope",
      "subscriptionExpires",
      "lastBillingCheckoutSessionId",
      "lastBillingTransactionId",
      "billingUpdatedAt",
      "currentSubscriptionId",
      "subscriptionStartedAt",
      "subscriptionEndsAt",
      "subscriptionCanceledAt",
      "billingCustomerId",
      "billingProvider",

      "roles",
      "permissions",
      "entitlements",

      "accountLocked",
      "accountStatus",
      "publicVisibility",
      "interactionBlocked",
      "loginAllowed",

      "suspended",
      "suspensionReason",
      "suspensionSource",
      "suspensionEndsAt",
      "suspendedAt",
      "suspendedAtMs",
      "suspendedBy",
      "unsuspendedAtMs",
      "unsuspendedBy",

      "deletionRequestedAt",
      "deletionRequestedBy",
      "deletionUndoUntil",
      "purgeAfter",
      "deletedAt",
      "deletionRestoreStatus",
      "deletionRestoreSuspended",
      "deletionRestoreSuspensionReason",
      "deletionRestoreSuspensionSource",
      "deletionRestoreSuspensionEndsAt",
      "purgeStartedAt",
      "purgeAttemptCount",
      "purgeLastAttemptAt",

      "statusUpdatedAt",
      "statusUpdatedBy",
      "moderatedBy",
      "moderatedAt",
      "lastStatusChangeAt"
    ]);
  }

  function adminModerationOnly() {
    return affectedUserKeys().hasOnly([
      "accountLocked",
      "suspended",
      "suspensionReason",
      "suspendedAt",
      "accountStatus",
      "moderatedBy",
      "moderatedAt",
      "lastStatusChangeAt"
    ]);
  }

  function initialTermsDefaultsOk() {
    return hasField("acceptedTerms")
      && request.resource.data.acceptedTerms is map
      && request.resource.data.acceptedTerms.keys().hasAny(["accepted"])
      && request.resource.data.acceptedTerms.accepted == false;
  }

  function commonCreateDefaultsOk() {
    return request.resource.data.keys().hasAny(["uid"])
      && request.resource.data.uid == uid()
      && !hasField("adultConsent")
      && !hasField("ageReverification")
      && !hasField("ageReverificationRestrictedAt")
      && hasField("registrationFlowVersion")
      && hasField("initialAdultConsentRequired")
      && request.resource.data.initialAdultConsentRequired == true
      && hasField("registrationCompletedAt")
      && request.resource.data.registrationCompletedAt == null
      && hasField("profileCompleted")
      && request.resource.data.profileCompleted == false
      && initialTermsDefaultsOk()

      && (!hasField("role") || request.resource.data.role == "free")
      && (!hasField("tier") || request.resource.data.tier == "free")
      && (!hasField("isSubscriber") || request.resource.data.isSubscriber == false)
      && (!hasField("monthlyPayer") || request.resource.data.monthlyPayer == false)
      && (!hasField("subscriptionStatus")
        || request.resource.data.subscriptionStatus == "inactive")
      && (!hasField("subscriptionScope")
        || request.resource.data.subscriptionScope == null)
      && (!hasField("subscriptionExpires")
        || request.resource.data.subscriptionExpires == null)
      && (!hasField("lastBillingCheckoutSessionId")
        || request.resource.data.lastBillingCheckoutSessionId == null)
      && (!hasField("lastBillingTransactionId")
        || request.resource.data.lastBillingTransactionId == null)
      && (!hasField("billingUpdatedAt")
        || request.resource.data.billingUpdatedAt == null)

      && (!hasField("roles") || request.resource.data.roles == ["user"])
      && (!hasField("permissions") || request.resource.data.permissions == [])
      && (!hasField("entitlements") || request.resource.data.entitlements == [])

      && (!hasField("accountLocked") || request.resource.data.accountLocked == false)
      && (!hasField("accountStatus") || request.resource.data.accountStatus == "active")
      && (!hasField("loginAllowed") || request.resource.data.loginAllowed == true)
      && (!hasField("suspended") || request.resource.data.suspended == false)
      && (!hasField("suspensionReason")
        || request.resource.data.suspensionReason == null)
      && (!hasField("suspensionSource")
        || request.resource.data.suspensionSource == null)
      && (!hasField("suspensionEndsAt")
        || request.resource.data.suspensionEndsAt == null)
      && (!hasField("deletionRequestedAt")
        || request.resource.data.deletionRequestedAt == null)
      && (!hasField("deletionRequestedBy")
        || request.resource.data.deletionRequestedBy == null)
      && (!hasField("deletionUndoUntil")
        || request.resource.data.deletionUndoUntil == null)
      && (!hasField("purgeAfter") || request.resource.data.purgeAfter == null);
  }

  function createVisibilityDefaultsOk() {
    return (
        request.resource.data.registrationFlowVersion == "v2"
        && (!hasField("publicVisibility")
          || request.resource.data.publicVisibility == "visible")
        && (!hasField("interactionBlocked")
          || request.resource.data.interactionBlocked == false)
      )
      || (
        request.resource.data.registrationFlowVersion == "v3-private-by-default"
        && hasField("publicVisibility")
        && request.resource.data.publicVisibility == "hidden"
        && hasField("interactionBlocked")
        && request.resource.data.interactionBlocked == true
      );
  }

  function createDefaultsOk() {
    return commonCreateDefaultsOk() && createVisibilityDefaultsOk();
  }

  function acceptedTermsReady() {
    return request.resource.data.keys().hasAny(["acceptedTerms"])
      && request.resource.data.acceptedTerms is map
      && request.resource.data.acceptedTerms.keys().hasAny(["accepted"])
      && request.resource.data.acceptedTerms.accepted == true;
  }

  function adultConsentReady() {
    return (
        request.resource.data.keys().hasAny(["initialAdultConsentRequired"])
        && request.resource.data.initialAdultConsentRequired == false
      )
      || (
        request.resource.data.keys().hasAny(["adultConsent"])
        && request.resource.data.adultConsent is map
        && request.resource.data.adultConsent.keys().hasAny(["accepted"])
        && request.resource.data.adultConsent.accepted == true
      );
  }

  function selfCompletingRegistration() {
    return isSelf(userId)
      && (
        !resource.data.keys().hasAny(["profileCompleted"])
        || resource.data.profileCompleted != true
      )
      && request.resource.data.profileCompleted == true
      && (
        !resource.data.keys().hasAny(["accountStatus"])
        || resource.data.accountStatus == "active"
      )
      && request.resource.data.accountStatus == "active"
      && authEmailVerified()
      && request.resource.data.emailVerified == true
      && acceptedTermsReady()
      && adultConsentReady()
      && request.resource.data.publicVisibility == "visible"
      && request.resource.data.interactionBlocked == false
      && request.resource.data.registrationCompletedAt == request.time
      && affectedUserKeys().hasOnly([
        "nickname",
        "nicknameHistory",
        "gender",
        "orientation",
        "estado",
        "municipio",
        "profileCompleted",
        "publicVisibility",
        "interactionBlocked",
        "registrationCompletedAt",
        "updatedAt",
        "updatedAtMs"
      ]);
  }

  allow get: if isSelf(userId) || isAdminActor();
  allow list: if false;

  allow create: if isSelf(userId)
    && emailVerifiedMatchesToken()
    && createDefaultsOk();

  allow update: if
    selfCompletingRegistration()
    || (
      isSelf(userId)
      && !selfChangingSensitiveKeys()
      && emailVerifiedSafeOnUpdate()
    )
    || (
      isAdminActor()
      && adminModerationOnly()
    );

  allow delete: if false;
}
