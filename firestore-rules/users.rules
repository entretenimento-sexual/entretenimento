// ==============================================================
// USERS (privado)
// ==============================================================
//
// Responsabilidade:
// - permitir ao prﾃδｳprio usuﾃδ｡rio atualizar dados comuns de perfil;
// - impedir adulteraﾃδｧﾃδ｣o de autenticaﾃδｧﾃδ｣o, privilﾃδｩgios, billing, lifecycle
//   e compliance;
// - permitir que criaﾃδｧﾃδ｣o inicial traga somente valores seguros/default;
// - reservar alteraﾃδｧﾃδｵes administrativas/financeiras/compliance para backend
//   confiﾃδ｡vel.
//
// Seguranﾃδｧa:
// - Cloud Functions com Admin SDK podem atualizar campos protegidos;
// - cliente web/mobile nunca deve promover role, ativar assinatura,
//   criar entitlement embutido, manipular suspensﾃδ｣o/exclusﾃδ｣o ou registrar
//   consentimento adulto diretamente;
// - claims administrativas continuam sendo a autoridade para aﾃδｧﾃδｵes de staff.
//
// Correﾃδｧﾃδ｣o crﾃδｭtica jﾃδ｡ preservada:
// - users/{uid}.emailVerified, quando enviado pelo cliente, deve refletir
//   request.auth.token.email_verified.
//
// ﾃ｢ﾅ凪ｦ ARQUIVO MODULAR: Nﾃθ丹 pode ter `rules_version` nem
//    `service cloud.firestore`.
// ==============================================================

match /users/{userId} {

  function isAdminActor() {
    return isAdmin();
  }

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function emailVerifiedMatchesToken() {
    return !hasField("emailVerified")
      || request.resource.data.emailVerified
        == (request.auth.token.email_verified == true);
  }

  /**
   * Campos controlados exclusivamente por backend confiﾃδ｡vel ou fluxo
   * administrativo especﾃδｭfico.
   *
   * Um usuﾃδ｡rio autenticado nﾃδ｣o pode alterﾃδ｡-los em update, mesmo no prﾃδｳprio
   * documento.
   */
  function selfChangingSensitiveKeys() {
    return request.resource.data.diff(resource.data).changedKeys().hasAny([
      // Compliance / aceite adulto
      "adultConsent",

      // Plano / autorizaﾃδｧﾃδ｣o financeira
      "role",
      "tier",
      "isSubscriber",
      "subscriptionStatus",
      "subscriptionScope",
      "lastBillingCheckoutSessionId",
      "lastBillingTransactionId",
      "billingUpdatedAt",
      "currentSubscriptionId",
      "subscriptionStartedAt",
      "subscriptionEndsAt",
      "subscriptionCanceledAt",
      "billingCustomerId",
      "billingProvider",

      // ACL / privilﾃδｩgios
      "roles",
      "permissions",
      "entitlements",

      // Lifecycle / visibilidade / bloqueio
      "accountLocked",
      "accountStatus",
      "publicVisibility",
      "interactionBlocked",
      "loginAllowed",

      "suspended",
      "suspensionReason",
      "suspensionSource",
      "suspensionEndsAt",
      "suspendedAt",
      "suspendedAtMs",
      "suspendedBy",
      "unsuspendedAtMs",
      "unsuspendedBy",

      "deletionRequestedAt",
      "deletionRequestedBy",
      "deletionUndoUntil",
      "purgeAfter",

      "statusUpdatedAt",
      "statusUpdatedBy",
      "moderatedBy",
      "moderatedAt",
      "lastStatusChangeAt"
    ]);
  }

  /**
   * Fluxo administrativo legado via cliente.
   *
   * Observaﾃδｧﾃδ｣o:
   * - novas operaﾃδｧﾃδｵes sensﾃδｭveis devem preferencialmente ocorrer por callable
   *   function auditada;
   * - esta lista ﾃδｩ mantida restrita para nﾃδ｣o permitir ediﾃδｧﾃδ｣o financeira por
   *   administradores via escrita genﾃδｩrica no documento.
   */
  function adminModerationOnly() {
    return request.resource.data.diff(resource.data).changedKeys().hasOnly([
      "accountLocked",
      "suspended",
      "suspensionReason",
      "suspendedAt",
      "accountStatus",
      "moderatedBy",
      "moderatedAt",
      "lastStatusChangeAt"
    ]);
  }

  /**
   * Valores aceitﾃδ｡veis na criaﾃδｧﾃδ｣o de um novo usuﾃδ｡rio pelo cliente.
   *
   * Campos de acesso podem existir somente com defaults nﾃδ｣o privilegiados.
   * Benefﾃδｭcios pagos, transaﾃδｧﾃδｵes, estados de lifecycle e aceite de compliance
   * nﾃδ｣o podem nascer ativos por payload enviado pelo navegador.
   */
  function createDefaultsOk() {
    return request.resource.data.keys().hasAny(["uid"])
      && request.resource.data.uid == uid()

      // Compliance inicial: aceite adulto ﾃδｩ gravado pela Cloud Function
      && !hasField("adultConsent")

      // Projeﾃδｧﾃδ｣o financeira inicial sem benefﾃδｭcio pago
      && (!hasField("role") || request.resource.data.role == "free")
      && (!hasField("tier") || request.resource.data.tier == "free")
      && (!hasField("isSubscriber") || request.resource.data.isSubscriber == false)
      && (!hasField("subscriptionStatus")
        || request.resource.data.subscriptionStatus == "inactive")
      && (!hasField("subscriptionScope")
        || request.resource.data.subscriptionScope == null)
      && (!hasField("lastBillingCheckoutSessionId")
        || request.resource.data.lastBillingCheckoutSessionId == null)
      && (!hasField("lastBillingTransactionId")
        || request.resource.data.lastBillingTransactionId == null)
      && (!hasField("billingUpdatedAt")
        || request.resource.data.billingUpdatedAt == null)

      // ACL inicial sem elevaﾃδｧﾃδ｣o de privilﾃδｩgio
      && (!hasField("roles") || request.resource.data.roles == ["user"])
      && (!hasField("permissions") || request.resource.data.permissions == [])
      && (!hasField("entitlements") || request.resource.data.entitlements == [])

      // Lifecycle inicial em estado normal
      && (!hasField("accountLocked") || request.resource.data.accountLocked == false)
      && (!hasField("accountStatus") || request.resource.data.accountStatus == "active")
      && (!hasField("publicVisibility")
        || request.resource.data.publicVisibility == "visible")
      && (!hasField("interactionBlocked")
        || request.resource.data.interactionBlocked == false)
      && (!hasField("loginAllowed") || request.resource.data.loginAllowed == true)
      && (!hasField("suspended") || request.resource.data.suspended == false)
      && (!hasField("suspensionReason")
        || request.resource.data.suspensionReason == null)
      && (!hasField("suspensionSource")
        || request.resource.data.suspensionSource == null)
      && (!hasField("suspensionEndsAt")
        || request.resource.data.suspensionEndsAt == null)
      && (!hasField("deletionRequestedAt")
        || request.resource.data.deletionRequestedAt == null)
      && (!hasField("deletionRequestedBy")
        || request.resource.data.deletionRequestedBy == null)
      && (!hasField("deletionUndoUntil")
        || request.resource.data.deletionUndoUntil == null)
      && (!hasField("purgeAfter") || request.resource.data.purgeAfter == null);
  }

  allow get: if isSelf(userId) || isAdminActor();
  allow list: if false;

  allow create: if isSelf(userId)
    && emailVerifiedMatchesToken()
    && createDefaultsOk();

  allow update: if
    (
      isSelf(userId)
      && !selfChangingSensitiveKeys()
      && emailVerifiedMatchesToken()
    )
    || (
      isAdminActor()
      && adminModerationOnly()
    );

  allow delete: if false;
}

// =============================================================
//                  FIM DO USERS.RULES
// =============================================================
