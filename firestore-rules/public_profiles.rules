// firestore-rules/public_profiles.rules
// =========================================================================
// PUBLIC PROFILES (consultable / discovery)
// =========================================================================
match /public_profiles/{userId} {
  // Read requires login.
  allow get, list: if signedIn();

  // -----------------------------------------------------------------------
  // Local helpers
  // -----------------------------------------------------------------------

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function hasExistingField(field) {
    return resource.data.keys().hasAny([field]);
  }

  function fieldOrNull(field) {
    return hasField(field) ? request.resource.data[field] : null;
  }

  function existingFieldOrNull(field) {
    return hasExistingField(field) ? resource.data[field] : null;
  }

  function immutableIfExisting(field) {
    return !hasExistingField(field)
      || fieldOrNull(field) == existingFieldOrNull(field);
  }

  function immutableExistingOrAbsent(field) {
    return hasExistingField(field)
      ? fieldOrNull(field) == existingFieldOrNull(field)
      : !hasField(field);
  }

  function optStringSized(field, min, max) {
    return !hasField(field)
      || request.resource.data[field] == null
      || (request.resource.data[field] is string
          && request.resource.data[field].size() >= min
          && request.resource.data[field].size() <= max);
  }

  function optUrl(field, maxLen) {
    return !hasField(field)
      || request.resource.data[field] == null
      || (request.resource.data[field] is string
          && request.resource.data[field].size() <= maxLen
          && request.resource.data[field].matches('^https?://.*'));
  }

  function optNumberInRange(field, min, max) {
    return !hasField(field)
      || request.resource.data[field] == null
      || (request.resource.data[field] is number
          && request.resource.data[field] >= min
          && request.resource.data[field] <= max);
  }

  function optGeohash(field) {
    return !hasField(field)
      || request.resource.data[field] == null
      || (request.resource.data[field] is string
          && request.resource.data[field].size() >= 5
          && request.resource.data[field].size() <= 12
          && request.resource.data[field]
            .matches('^[0123456789bcdefghjkmnpqrstuvwxyz]{5,12}$'));
  }

  function nicknameCoherent() {
    let nick = fieldOrNull("nickname");
    let norm = fieldOrNull("nicknameNormalized");
    return (nick == null && norm == null) || (nick != null && norm != null);
  }

  function geoCoherent() {
    let lat = fieldOrNull("latitude");
    let lng = fieldOrNull("longitude");
    let gh  = fieldOrNull("geohash");
    return (lat == null && lng == null && gh == null)
      || (lat != null && lng != null && gh != null);
  }

  function noClientDiscoveryFieldsOnCreate() {
    return !request.resource.data.keys().hasAny([
      "normalizedGender",
      "normalizedOrientation",
      "interestedInGenders",
      "interestedInOrientations",
      "compatibilityReady",
      "discoveryNormalizedAt"
    ]);
  }

  function discoveryFieldsUnchangedOnUpdate() {
    return fieldOrNull("normalizedGender") == existingFieldOrNull("normalizedGender")
      && fieldOrNull("normalizedOrientation") == existingFieldOrNull("normalizedOrientation")
      && fieldOrNull("interestedInGenders") == existingFieldOrNull("interestedInGenders")
      && fieldOrNull("interestedInOrientations") == existingFieldOrNull("interestedInOrientations")
      && fieldOrNull("compatibilityReady") == existingFieldOrNull("compatibilityReady")
      && fieldOrNull("discoveryNormalizedAt") == existingFieldOrNull("discoveryNormalizedAt");
  }

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "uid",
      "nickname",
      "nicknameNormalized",
      "avatarUrl",
      "photoURL",
      "municipio",
      "estado",
      "gender",
      "orientation",
      "normalizedGender",
      "normalizedOrientation",
      "interestedInGenders",
      "interestedInOrientations",
      "compatibilityReady",
      "discoveryNormalizedAt",
      "role",
      "latitude",
      "longitude",
      "geohash",
      "createdAt",
      "updatedAt"
    ]);
  }

  function validClientEditablePublicProfilePayload() {
    return allowedKeys()
      && (request.resource.data.uid is string)
      && request.resource.data.uid == uid()
      && optTimestamp("updatedAt")
      && nicknameCoherent()
      && optStringSized("nickname", 3, 40)
      && (
        !hasField("nicknameNormalized")
        || request.resource.data.nicknameNormalized == null
        || (
          request.resource.data.nicknameNormalized is string
          && request.resource.data.nicknameNormalized.matches('^[a-z0-9._-]{3,40}$')
        )
      )
      && optUrl("avatarUrl", 1024)
      && optUrl("photoURL", 1024)
      && geoCoherent()
      && optNumberInRange("latitude", -90, 90)
      && optNumberInRange("longitude", -180, 180)
      && optGeohash("geohash")
      && optStringSized("municipio", 1, 80)
      && optStringSized("estado", 1, 40)
      && optStringSized("gender", 1, 40)
      && optStringSized("orientation", 1, 40);
  }

  function validPublicProfileCreatePayload() {
    return validClientEditablePublicProfilePayload()
      && optTimestamp("createdAt")
      && optTimestamp("discoveryNormalizedAt")
      && optStringSized("normalizedGender", 3, 20)
      && optStringSized("normalizedOrientation", 3, 20)
      && (!hasField("interestedInGenders")
        || request.resource.data.interestedInGenders == null
        || (request.resource.data.interestedInGenders is list
          && request.resource.data.interestedInGenders.size() <= 8))
      && (!hasField("interestedInOrientations")
        || request.resource.data.interestedInOrientations == null
        || (request.resource.data.interestedInOrientations is list
          && request.resource.data.interestedInOrientations.size() <= 8))
      && (!hasField("compatibilityReady")
        || request.resource.data.compatibilityReady == null
        || request.resource.data.compatibilityReady is bool)
      && optStringSized("role", 3, 20);
  }

  allow create: if (
    isSelf(userId)
    && validPublicProfileCreatePayload()
    && noClientDiscoveryFieldsOnCreate()
    && request.resource.data.createdAt == request.time
    && request.resource.data.updatedAt == request.time
    && request.resource.data.role == "free"
  );

  allow update: if (
    isSelf(userId)
    && validClientEditablePublicProfilePayload()
    && discoveryFieldsUnchangedOnUpdate()
    && immutableIfExisting("uid")
    && immutableExistingOrAbsent("createdAt")
    && request.resource.data.updatedAt == request.time
    && immutableExistingOrAbsent("role")
  );

  allow delete: if false;
}
