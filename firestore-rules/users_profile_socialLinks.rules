// ===============================================================
// USERS / profileData / socialLinks (privado)
// - Fonte de verdade privada do dono
// - Criação/alteração: somente dono com assinatura ativa
// - Remoção: o dono mantém controle mesmo após o término da assinatura
// - Leitura: somente dono
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
// C:\entretenimento\firestore-rules\users_profile_socialLinks.rules
// ===============================================================
match /users/{userId}/profileData/socialLinks {

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "facebook","instagram","twitter","linkedin","youtube","tiktok","snapchat",
      "sexlog","d4swing",
      "hotvips","privacy","onlyfans","fansly","linktree"
    ]);
  }

  function validPayload() {
    return allowedKeys()
      && optString("facebook")
      && optString("instagram")
      && optString("twitter")
      && optString("linkedin")
      && optString("youtube")
      && optString("tiktok")
      && optString("snapchat")
      && optString("sexlog")
      && optString("d4swing")
      && optString("hotvips")
      && optString("privacy")
      && optString("onlyfans")
      && optString("fansly")
      && optString("linktree");
  }

  function removesOnly() {
    let diff = request.resource.data.diff(resource.data);
    return diff.addedKeys().size() == 0
      && diff.changedKeys().size() == 0
      && diff.removedKeys().size() > 0;
  }

  allow get: if isSelf(userId);
  allow list: if false;

  allow create: if isSelf(userId)
    && isActiveSubscriber(userId)
    && validPayload();

  allow update: if isSelf(userId)
    && validPayload()
    && (
      isActiveSubscriber(userId)
      || removesOnly()
    );

  // Exclusão integral continua disponível por privacidade, sem republicação.
  allow delete: if isSelf(userId);
}
// ===============================================================
//                    FIM DO SOCIAL.LINKS
// ===============================================================