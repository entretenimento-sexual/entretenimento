// ===============================================================
// PUBLIC SOCIAL LINKS (espelho público)
// - Somente subset publicado
// - Escrita: somente dono
// - Leitura: exige login (alinhado ao seu /public_profiles)
// - Evita LIST (padrão anti-scraping)
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`.
// uso de helpers globais
// C:\entretenimento\firestore-rules\public_social_links.rules
// ===============================================================
match /public_social_links/{userId} {

  allow get: if signedIn();
  allow list: if false;

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "uid",
      "facebook","instagram","twitter","linkedin","youtube","tiktok","snapchat",
      "sexlog","d4swing",

      // ✅ novo + sugestões
      "hotvips",
      "privacy",
      "onlyfans",
      "fansly",
      "linktree",

      "updatedAt"
    ]);
  }

  function validPayload() {
    return request.resource.data.uid == uid()
      && allowedKeys()
      && optString("facebook")
      && optString("instagram")
      && optString("twitter")
      && optString("linkedin")
      && optString("youtube")
      && optString("tiktok")
      && optString("snapchat")
      && optString("sexlog")
      && optString("d4swing")

      // ✅ novo + sugestões
      && optString("hotvips")
      && optString("privacy")
      && optString("onlyfans")
      && optString("fansly")
      && optString("linktree")

      && optTimestamp("updatedAt");
  }

  allow create: if isSelf(userId)
    && validPayload()
    && request.resource.data.updatedAt == request.time;

  allow update: if isSelf(userId)
    && validPayload()
    && request.resource.data.uid == resource.data.uid
    && request.resource.data.updatedAt == request.time
    && request.resource.data.diff(resource.data).changedKeys().hasOnly([
      "facebook","instagram","twitter","linkedin","youtube","tiktok","snapchat",
      "sexlog","d4swing",

      // ✅ novo + sugestões
      "hotvips",
      "privacy",
      "onlyfans",
      "fansly",
      "linktree",

      "updatedAt"
    ]);

  allow delete: if isSelf(userId);
}
// ===============================================================
                   // FIM PUBLIC SOCIAL LINKS
// ===============================================================
