// firestore-rules/public_profiles_photos.rules
// ===============================================================
// PUBLIC_PROFILES / photos
// - projeção pública derivada da publicação
// - leitura pública autenticada apenas para fotos PUBLIC
// - escrita somente pelo próprio dono
// - Escrita ainda fica com o próprio dono; no futuro, pode migrar para Function
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// ===============================================================
match /public_profiles/{userId}/public_photos/{photoId} {

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "id",
      "ownerUid",
      "url",
      "alt",
      "createdAt",
      "publishedAt",
      "updatedAt",
      "visibility",
      "isCover",
      "orderIndex",
      "commentsEnabled",
      "reactionsEnabled"
    ]);
  }

  function optBool(field) {
    return !hasField(field)
      || request.resource.data[field] == null
      || request.resource.data[field] is bool;
  }

  function optNumber(field) {
    return !hasField(field)
      || request.resource.data[field] == null
      || request.resource.data[field] is number;
  }

  function validVisibility() {
    return hasField("visibility")
      && request.resource.data.visibility in ["FRIENDS", "SUBSCRIBERS", "PUBLIC"];
  }

  function validPayload() {
    return allowedKeys()
      && request.resource.data.id == photoId
      && request.resource.data.ownerUid == userId
      && request.resource.data.url is string
      && (!hasField("alt") || request.resource.data.alt is string)
      && request.resource.data.createdAt is number
      && request.resource.data.publishedAt is number
      && optNumber("updatedAt")
      && validVisibility()
      && optBool("isCover")
      && optNumber("orderIndex")
      && optBool("commentsEnabled")
      && optBool("reactionsEnabled");
  }

  function isPublicReadable() {
    return resource.data.visibility == "PUBLIC";
  }

  allow get: if isSelf(userId) || (signedIn() && isPublicReadable());
  allow list: if isSelf(userId) || (signedIn() && isPublicReadable());

  allow create, update: if isSelf(userId) && validPayload();
  allow delete: if isSelf(userId);
}
// ==============================================================
//           FIM DO PUBLIC_PROFILES_PHOTOS.RULES
// ==============================================================