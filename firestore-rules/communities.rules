// firestore-rules/communities.rules
// =============================================================================
// COMMUNITIES
// =============================================================================
// Comunidades sociais originadas de locais ou salas.
//
// Segurança:
// - usuário autenticado pode abrir uma comunidade com prévia pública;
// - membro ativo pode abrir comunidade restrita;
// - membership bloqueada nega acesso inclusive à prévia;
// - listagem global direta fica bloqueada até existir projeção/callable paginada;
// - criação, adesão, moderação e mutações são exclusivas do backend;
// - o cliente só pode ler o próprio documento de membership;
// - projeções de descoberta e índice pessoal são backend-only.
// =============================================================================

match /communities/{communityId} {
  function communityMembershipPath() {
    return /databases/$(database)/documents/communities/$(communityId)/members/$(uid());
  }

  function communityMembershipExists() {
    return signedIn() && exists(communityMembershipPath());
  }

  function communityMembershipStatus() {
    return get(communityMembershipPath()).data.status;
  }

  function hasActiveCommunityMembership() {
    return communityMembershipExists()
      && communityMembershipStatus() == "active";
  }

  function hasBlockedCommunityMembership() {
    return communityMembershipExists()
      && communityMembershipStatus() == "blocked";
  }

  function isPublicPreviewCommunity() {
    return resource.data.status == "active"
      && resource.data.moderation.state == "active"
      && resource.data.visibility == "public_preview"
      && resource.data.access.preview == "authenticated";
  }

  allow get: if signedIn()
    && !hasBlockedCommunityMembership()
    && (
      isPublicPreviewCommunity()
      || hasActiveCommunityMembership()
    );

  // Descoberta será feita por projeção/callable, evitando enumeração direta.
  allow list: if false;

  // Admin SDK não depende destas permissões.
  allow create, update, delete: if false;
}

match /communities/{communityId}/members/{memberUid} {
  // O usuário conhece somente o próprio vínculo e papel.
  allow get: if signedIn() && memberUid == uid();

  // Listas de membros, adesão e mudanças de papel passam pelo backend.
  allow list, create, update, delete: if false;
}

// Projeção sanitizada usada exclusivamente pela callable de descoberta.
match /community_discovery_index/{communityId} {
  allow read, write: if false;
}

// Projeção futura das comunidades do usuário. Backend-only nesta fase.
match /community_user_index/{userId}/items/{communityId} {
  allow read, write: if false;
}
