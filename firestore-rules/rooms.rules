// ================================================================
                       // ROOMS.RULES
    // - Coleção raiz: rooms/{roomId}
    // - Subcollections: messages, invites, participants
    // - Read: somente participantes (anti-scraping)
    // - Write: somente participantes, mas só owner pode mudar participantes e detalhes do room (
    //   isso evita negação em transações onde room update + participant set rodam juntos, e mantém controle de quem pode mudar o que).
    // - Messages: somente participantes, mas só pode criar mensagens com senderId == uid,
    //   e só pode atualizar status de mensagens recebidas (não pode mudar mensagens que enviou).
    // - Invites: somente envolvidos (sender ou receiver), com regras específicas de quem pode criar/atualizar/deletar.
    // ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
    // firestore-rules\rooms.rules
// ================================================================
match /rooms/{roomId} {
  function isRoomParticipant() {
    return signedIn() && (uid() in resource.data.participants);
  }

  function isRoomOwner() {
    return signedIn() && resource.data.createdBy == uid();
  }

  function isLegacyRoomPayload() {
  return !hasField("type") && !hasField("targetId");
}

function validCreateLegacyRoom() {
  return isLegacyRoomPayload()
    && allowedKeys()
    && request.resource.data.senderId == uid()
    && request.resource.data.receiverId is string
    && request.resource.data.receiverId != uid()
    && request.resource.data.roomId is string
    && request.resource.data.status == "pending"
    && isTs(request.resource.data.sentAt)
    && isTs(request.resource.data.expiresAt)
    && (!hasField("updatedAt") || request.resource.data.updatedAt == request.time)
    && (!hasField("respondedAt") || request.resource.data.respondedAt == null);
}

  // ------------------------------------------------------------
  // JOIN BY INVITE (root invites)
  // DocId: invites/room:<roomId>:to:<uid>
  // ------------------------------------------------------------
  function joinInviteId() {
    return "room:" + roomId + ":to:" + uid();
  }

  function hasPendingJoinInvite() {
    let invPath = /databases/$(database)/documents/invites/$(joinInviteId());
    return exists(invPath)
      && get(invPath).data.status == "pending"
      && get(invPath).data.receiverId == uid()
      && (
        // compat: v2 (targetId) OU legacy (roomId)
        (("targetId" in get(invPath).data) && get(invPath).data.targetId == roomId)
        || (("roomId" in get(invPath).data) && get(invPath).data.roomId == roomId)
      )
      && get(invPath).data.expiresAt > request.time;
  }

  function isJoinUpdateShape() {
    // não é participante ainda
    return signedIn()
      && !(uid() in resource.data.participants)

      // só pode mudar participants + lastActivity
      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "participants",
        "lastActivity"
      ])

      // participants: list
      && (request.resource.data.participants is list)
      && (resource.data.participants is list)

      // adiciona a si mesmo
      && (uid() in request.resource.data.participants)
      && !(uid() in resource.data.participants)

      // só cresce +1 e preserva todos os antigos
      && request.resource.data.participants.size() == resource.data.participants.size() + 1
      && request.resource.data.participants.hasAll(resource.data.participants)

      // força serverTimestamp em lastActivity
      && request.resource.data.lastActivity == request.time;
  }

  allow read: if isRoomParticipant();

  allow create: if signedIn()
    && request.resource.data.createdBy == uid()
    && request.resource.data.participants is list
    && (uid() in request.resource.data.participants)
    && isStr(request.resource.data.roomName)
    && ("creationTime" in request.resource.data) && isTs(request.resource.data.creationTime);

  // ✅ update normal (seu comportamento atual) OU join-by-invite
  allow update: if
    (
      isRoomParticipant()
      && (
        (isRoomOwner()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "roomName",
            "description",
            "expirationDate",
            "maxParticipants",
            "isPrivate",
            "roomType",
            "visibility",
            "participants",
            "lastActivity",
            "lastMessage"
          ])
        )
        ||
        (!isRoomOwner()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "lastActivity",
            "lastMessage"
          ])
        )
      )
    )
    ||
    (
      // join controlado
      hasPendingJoinInvite()
      && isJoinUpdateShape()
    );

  allow delete: if false;
}
// ================================================================
//                        FIM DO ROOMS.RULES
// ================================================================
