// ===============================================================
// PUBLIC_PROFILES / public_videos
// ===============================================================

match /public_profiles/{userId}/public_videos/{videoId} {

  function videoPath() {
    return /databases/$(database)/documents/public_profiles/$(userId)/public_videos/$(videoId);
  }

  function videoExists() {
    return exists(videoPath());
  }

  function videoData() {
    return get(videoPath()).data;
  }

  function isApprovedPublicVideoData(data) {
    return data.visibility == "PUBLIC"
      && data.moderationStatus == "APPROVED";
  }

  function isPublicReadableVideo() {
    return resource.data.visibility == "PUBLIC"
      && resource.data.moderationStatus == "APPROVED";
  }

  allow get: if signedIn() && (isSelf(userId) || isPublicReadableVideo());

  allow list: if signedIn()
    && resource.data.visibility == "PUBLIC"
    && resource.data.moderationStatus == "APPROVED";

  allow create, update, delete: if false;

  match /likes/{viewerUid} {
    allow get: if signedIn() && request.auth.uid == viewerUid;
    allow list: if false;
    allow create, update, delete: if false;
  }

  match /ratings/{viewerUid} {
    allow get: if signedIn() && request.auth.uid == viewerUid;
    allow list: if false;
    allow create, update, delete: if false;
  }

  match /comments/{commentId} {
    allow get: if signedIn()
      && (
        isSelf(userId)
        || (
          resource.data.status == "VISIBLE"
          && videoExists()
          && isApprovedPublicVideoData(videoData())
        )
      );

    allow list: if signedIn()
      && (
        isSelf(userId)
        || (
          resource.data.status == "VISIBLE"
          && videoExists()
          && isApprovedPublicVideoData(videoData())
        )
      );

    allow create, update, delete: if false;
  }
}

// ------------------------------------------------------------
// Collection group: public_videos
// ------------------------------------------------------------
match /{path=**}/public_videos/{videoId} {
  allow list: if signedIn()
    && resource.data.visibility == "PUBLIC"
    && resource.data.moderationStatus == "APPROVED";

  allow get: if signedIn()
    && resource.data.visibility == "PUBLIC"
    && resource.data.moderationStatus == "APPROVED";

  allow create, update, delete: if false;
}

// ==============================================================
//           FIM DO PUBLIC_PROFILES_VIDEOS.RULES
// ==============================================================
