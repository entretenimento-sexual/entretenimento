// firestore-rules/user_intent_statuses.rules
// ============================================================================
// USER INTENT STATUSES / STATUS DE HOJE
// ============================================================================
// Status temporário de disponibilidade/intenção do usuário.
//
// Segurança:
// - leitura pública do app exige login e status ativo/visível;
// - o usuário pode ler o próprio status atual;
// - escrita comum direta é bloqueada;
// - publicação/ocultação devem passar pelas Cloud Functions;
// - expiração máxima e snapshots públicos são definidos pelo backend.
// ============================================================================
match /user_intent_statuses/{statusId} {
  function isOwnerStatus() {
    return signedIn() && resource.data.uid == uid();
  }

  function isVisibleStatus() {
    return resource.data.moderation.state == "active"
      && resource.data.visibility == "public_discovery"
      && resource.data.expiresAt > request.time.toMillis();
  }

  allow get: if signedIn() && (isVisibleStatus() || isOwnerStatus());
  allow list: if signedIn() && isVisibleStatus();

  allow create, update, delete: if false;
}
