{
  "name": "entretenimento",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:dev": "ng serve -c development",
    "start:emu": "ng serve -c dev-emu",
    "start:staging": "ng serve -c staging",
    "build": "ng build",
    "build:dev": "ng build -c development",
    "build:emu": "ng build -c dev-emu",
    "build:staging": "ng build -c staging",
    "build:prod": "ng build -c production",
    "build:safe": "npm run rules:build && npm run rules:check && ng build",
    "validate:local": "npm run rules:build && npm run rules:check && npm run functions:build && npm run build:emu",
    "test": "ng test",
    "functions:build": "npm --prefix functions run build",
    "emu:pre": "kill-port 4000 4400 4500 9099 8080 5001 8087 9000 9199 9150 || exit 0",
    "preemu:start": "npm run functions:build",
    "emu:start": "set FIREBASE_EMULATORS_ONLY=auth,firestore,storage,functions,pubsub,database,ui&& node scripts/dev/start-emulator-with-data.mjs",
    "emu:noui:start": "set FIREBASE_EMULATORS_ONLY=auth,firestore,storage,functions,pubsub,database&& node scripts/dev/start-emulator-with-data.mjs",
    "emu:discovery:start": "set FIREBASE_EMULATORS_ONLY=auth,firestore,functions&& node scripts/dev/start-emulator-with-data.mjs",
    "emu:media:start": "set FIREBASE_EMULATORS_ONLY=auth,firestore,storage,functions&& node scripts/dev/start-emulator-with-data.mjs",
    "emu": "npm run rules:build && npm run functions:build && npm run emu:start",
    "emu:noui": "npm run rules:build && npm run functions:build && npm run emu:noui:start",
    "emu:discovery": "npm run rules:build && npm run functions:build && npm run emu:discovery:start",
    "emu:media": "npm run rules:build && npm run functions:build && npm run emu:media:start",
    "emulators:start:ui": "start http://127.0.0.1:4000",
    "rules:build": "node firestore-rules/tools-rules/build-firestore-rules.mjs",
    "rules:check": "node firestore-rules/tools-rules/check-braces.mjs",
    "test:rules:rooms": "npm run rules:build && npm run rules:check && firebase emulators:exec --config firebase.rules-test.json --only firestore --project demo-entretenimento-rules \"vitest run --config vitest.rules.config.ts --reporter=verbose\"",
    "seed:hot-places:emu": "set FIRESTORE_EMULATOR_HOST=127.0.0.1:8080&& set FIREBASE_PROJECT_ID=entretenimento-sexual&& node scripts/dev/seed-regional-hot-places.mjs",
    "seed:venues:emu": "set FIRESTORE_EMULATOR_HOST=127.0.0.1:8080&& set FIREBASE_PROJECT_ID=entretenimento-sexual&& node scripts/dev/seed-venues.mjs",
    "seed:intents:emu": "set FIRESTORE_EMULATOR_HOST=127.0.0.1:8080&& set FIREBASE_PROJECT_ID=entretenimento-sexual&& node scripts/dev/seed-user-intent-statuses.mjs",
    "seed:notification-preferences:emu": "set FIRESTORE_EMULATOR_HOST=127.0.0.1:8080&& set FIREBASE_PROJECT_ID=entretenimento-sexual&& node scripts/dev/seed-notification-preferences.mjs",
    "deploy:rules": "npm run rules:build && npm run rules:check && firebase deploy --only firestore:rules",
    "deploy:rules:project": "npm run rules:build && npm run rules:check && firebase deploy --only firestore:rules --project entretenimento-sexual",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "deploy:indexes:project": "firebase deploy --only firestore:indexes --project entretenimento-sexual",
    "deploy:firestore": "npm run rules:build && npm run rules:check && firebase deploy --only firestore:rules,firestore:indexes --project entretenimento-sexual",
    "rules:watch": "node firestore-rules/tools-rules/build-firestore-rules.mjs --watch",
    "emulators": "npm run rules:build && node scripts/dev/start-emulator-with-data.mjs",
    "audit:prod": "npm audit --omit=dev",
    "audit:all": "npm audit"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/platform-browser-dynamic": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/operators": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "@popperjs/core": "^2.11.8",
    "@pqina/angular-pintura": "^9.0.3",
    "@sentry/tracing": "^7.120.4",
    "@tensorflow-models/blazeface": "^0.1.0",
    "@tensorflow/tfjs": "^4.22.0",
    "axios": "^1.15.2",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.1.0",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.8.0",
    "geofire-common": "^6.0.0",
    "idb-keyval": "^6.2.1",
    "ngx-toastr": "19.1.0",
    "rxfire": "^6.1.0",
    "rxjs": "^7.8.2",
    "ts-evaluator": "^2.0.0",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.9",
    "@angular/build": "^21.2.9",
    "@angular/cdk": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@angular/language-service": "^21.2.11",
    "@angular/localize": "^21.2.11",
    "@angular/material": "^21.2.9",
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@pqina/pintura": "^8.97.1",
    "@sentry/angular": "^10.51.0",
    "@types/estree": "^1.0.8",
    "@types/jsdom": "^21.1.7",
    "@types/offscreencanvas": "^2019.7.3",
    "@types/pica": "^9.0.4",
    "@types/triple-beam": "^1.3.5",
    "bootstrap": "^5.3.8",
    "cross-fetch": "^3.2.0",
    "eslint": "^9.39.4",
    "fake-indexeddb": "^6.2.4",
    "firebase-tools": "^15.16.0",
    "glob": "^11.0.3",
    "globals": "16.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^26.1.7",
    "kill-port": "^2.0.1",
    "open": "^10.2.0",
    "protobufjs": "^7.5.6",
    "rimraf": "^6.1.3",
    "tcp-port-used": "^1.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.5",
    "webpack-dev-server": "^5.2.3"
  },
  "overrides": {
    "core-js": "^3.23.3",
    "serialize-javascript": "7.0.4"
  }
}
