// ===== users.rules =====
// ==============================================================
// USERS (privado)
// ==============================================================
//
// Responsabilidade:
// - permitir ao próprio usuário atualizar dados comuns de perfil;
// - impedir adulteração de autenticação, privilégios, billing e lifecycle;
// - permitir que criação inicial traga somente valores seguros/default;
// - reservar alterações administrativas/financeiras para backend confiável.
//
// Segurança:
// - Cloud Functions com Admin SDK podem atualizar campos protegidos;
// - cliente web/mobile nunca deve promover role, ativar assinatura,
//   criar entitlement embutido ou manipular suspensão/exclusão;
// - claims administrativas continuam sendo a autoridade para ações de staff.
//
// Correção crítica já preservada:
// - users/{uid}.emailVerified, quando enviado pelo cliente, deve refletir
//   request.auth.token.email_verified.
//
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem
//    `service cloud.firestore`.
// ==============================================================

match /users/{userId} {

  function isAdminActor() {
    return isAdmin();
  }

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function emailVerifiedMatchesToken() {
    return !hasField("emailVerified")
      || request.resource.data.emailVerified
        == (request.auth.token.email_verified == true);
  }

  /**
   * Campos controlados exclusivamente por backend confiável ou fluxo
   * administrativo específico.
   *
   * Um usuário autenticado não pode alterá-los em update, mesmo no próprio
   * documento.
   */
  function selfChangingSensitiveKeys() {
    return request.resource.data.diff(resource.data).changedKeys().hasAny([
      // Plano / autorização financeira
      "role",
      "tier",
      "isSubscriber",
      "subscriptionStatus",
      "subscriptionScope",
      "lastBillingCheckoutSessionId",
      "lastBillingTransactionId",
      "billingUpdatedAt",
      "currentSubscriptionId",
      "subscriptionStartedAt",
      "subscriptionEndsAt",
      "subscriptionCanceledAt",
      "billingCustomerId",
      "billingProvider",

      // ACL / privilégios
      "roles",
      "permissions",
      "entitlements",

      // Lifecycle / visibilidade / bloqueio
      "accountLocked",
      "accountStatus",
      "publicVisibility",
      "interactionBlocked",
      "loginAllowed",

      "suspended",
      "suspensionReason",
      "suspensionSource",
      "suspensionEndsAt",
      "suspendedAt",
      "suspendedAtMs",
      "suspendedBy",
      "unsuspendedAtMs",
      "unsuspendedBy",

      "deletionRequestedAt",
      "deletionRequestedBy",
      "deletionUndoUntil",
      "purgeAfter",

      "statusUpdatedAt",
      "statusUpdatedBy",
      "moderatedBy",
      "moderatedAt",
      "lastStatusChangeAt"
    ]);
  }

  /**
   * Fluxo administrativo legado via cliente.
   *
   * Observação:
   * - novas operações sensíveis devem preferencialmente ocorrer por callable
   *   function auditada;
   * - esta lista é mantida restrita para não permitir edição financeira por
   *   administradores via escrita genérica no documento.
   */
  function adminModerationOnly() {
    return request.resource.data.diff(resource.data).changedKeys().hasOnly([
      "accountLocked",
      "suspended",
      "suspensionReason",
      "suspendedAt",
      "accountStatus",
      "moderatedBy",
      "moderatedAt",
      "lastStatusChangeAt"
    ]);
  }

  /**
   * Valores aceitáveis na criação de um novo usuário pelo cliente.
   *
   * Campos de acesso podem existir somente com defaults não privilegiados.
   * Benefícios pagos, transações e estados de lifecycle não podem nascer
   * ativos por payload enviado pelo navegador.
   */
  function createDefaultsOk() {
    return request.resource.data.keys().hasAny(["uid"])
      && request.resource.data.uid == uid()

      // Projeção financeira inicial sem benefício pago
      && (!hasField("role") || request.resource.data.role == "free")
      && (!hasField("tier") || request.resource.data.tier == "free")
      && (!hasField("isSubscriber") || request.resource.data.isSubscriber == false)
      && (!hasField("subscriptionStatus")
        || request.resource.data.subscriptionStatus == "inactive")
      && (!hasField("subscriptionScope")
        || request.resource.data.subscriptionScope == null)
      && (!hasField("lastBillingCheckoutSessionId")
        || request.resource.data.lastBillingCheckoutSessionId == null)
      && (!hasField("lastBillingTransactionId")
        || request.resource.data.lastBillingTransactionId == null)
      && (!hasField("billingUpdatedAt")
        || request.resource.data.billingUpdatedAt == null)

      // ACL inicial sem elevação de privilégio
      && (!hasField("roles") || request.resource.data.roles == ["user"])
      && (!hasField("permissions") || request.resource.data.permissions == [])
      && (!hasField("entitlements") || request.resource.data.entitlements == [])

      // Lifecycle inicial em estado normal
      && (!hasField("accountLocked") || request.resource.data.accountLocked == false)
      && (!hasField("accountStatus") || request.resource.data.accountStatus == "active")
      && (!hasField("publicVisibility")
        || request.resource.data.publicVisibility == "visible")
      && (!hasField("interactionBlocked")
        || request.resource.data.interactionBlocked == false)
      && (!hasField("loginAllowed") || request.resource.data.loginAllowed == true)
      && (!hasField("suspended") || request.resource.data.suspended == false)
      && (!hasField("suspensionReason")
        || request.resource.data.suspensionReason == null)
      && (!hasField("suspensionSource")
        || request.resource.data.suspensionSource == null)
      && (!hasField("suspensionEndsAt")
        || request.resource.data.suspensionEndsAt == null)
      && (!hasField("deletionRequestedAt")
        || request.resource.data.deletionRequestedAt == null)
      && (!hasField("deletionRequestedBy")
        || request.resource.data.deletionRequestedBy == null)
      && (!hasField("deletionUndoUntil")
        || request.resource.data.deletionUndoUntil == null)
      && (!hasField("purgeAfter") || request.resource.data.purgeAfter == null);
  }

  allow get: if isSelf(userId) || isAdminActor();
  allow list: if false;

  allow create: if isSelf(userId)
    && emailVerifiedMatchesToken()
    && createDefaultsOk();

  allow update: if
    (
      isSelf(userId)
      && !selfChangingSensitiveKeys()
      && emailVerifiedMatchesToken()
    )
    || (
      isAdminActor()
      && adminModerationOnly()
    );

  allow delete: if false;
}

