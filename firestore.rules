// ===== public_profiles.rules =====
// firestore-rules/public_profiles.rules
// =========================================================================
// PUBLIC PROFILES (consultável / discovery)
//
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`.
// uso de helpers globais
// ✅ Depende dos helpers globais em _helpers.rules:
//    - signedIn(), uid(), isSelf()
//    - optTimestamp()  (se você mantém esse helper global)
// =========================================================================
match /public_profiles/{userId} {
  // Leitura: exige login (evita scraping público).
  // Obs.: para queries (where/orderBy) o Firestore usa "list".
  allow get, list: if signedIn();

  // -----------------------------------------------------------------------
  // Helpers locais (SAFE)
  // - Evita evaluation error quando campo opcional está ausente (undefined)
  // - Usa keys().hasAny([field]) antes de acessar request.resource.data[field]
  // -----------------------------------------------------------------------

  // Existe no payload?
  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  // Retorna valor ou null (se ausente)
  function fieldOrNull(field) {
    return hasField(field) ? request.resource.data[field] : null;
  }

  // String opcional, com range de tamanho
  function optStringSized(field, min, max) {
    return !hasField(field)
      || request.resource.data[field] == null
      || (request.resource.data[field] is string
          && request.resource.data[field].size() >= min
          && request.resource.data[field].size() <= max);
  }

  // URL opcional: validação básica (http/https) + tamanho máximo
  function optUrl(field, maxLen) {
    return !hasField(field)
      || request.resource.data[field] == null
      || (request.resource.data[field] is string
          && request.resource.data[field].size() <= maxLen
          && request.resource.data[field].matches('^https?://.*'));
  }

  // Number opcional, com range
  function optNumberInRange(field, min, max) {
    return !hasField(field)
      || request.resource.data[field] == null
      || (request.resource.data[field] is number
          && request.resource.data[field] >= min
          && request.resource.data[field] <= max);
  }

  // Geohash opcional (base32), tamanho 5..12
  function optGeohash(field) {
    return !hasField(field)
      || request.resource.data[field] == null
      || (request.resource.data[field] is string
          && request.resource.data[field]
            .matches('^[0123456789bcdefghjkmnpqrstuvwxyz]{5,12}$'));
  }

  // nickname e nicknameNormalized coerentes
  function nicknameCoherent() {
    let nick = fieldOrNull("nickname");
    let norm = fieldOrNull("nicknameNormalized");
    return (nick == null && norm == null) || (nick != null && norm != null);
  }

  // geo: ou os 3 null/ausentes, ou os 3 preenchidos
  function geoCoherent() {
    let lat = fieldOrNull("latitude");
    let lng = fieldOrNull("longitude");
    let gh  = fieldOrNull("geohash");
    return (lat == null && lng == null && gh == null)
      || (lat != null && lng != null && gh != null);
  }

  // -----------------------------------------------------------------------
  // Whitelist rígida: nenhum campo fora do schema
  // -----------------------------------------------------------------------
  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "uid",
      "nickname",
      "nicknameNormalized",
      "avatarUrl",
      "photoURL",
      "municipio",
      "estado",
      "gender",
      "orientation",
      "role",
      "latitude",
      "longitude",
      "geohash",
      "createdAt",
      "updatedAt"
    ]);
  }

  // -----------------------------------------------------------------------
  // Validação do payload FINAL (create/update)
  // Em update: request.resource.data já é o documento final (merge aplicado).
  // -----------------------------------------------------------------------
  function validPublicProfilePayload() {
    return allowedKeys()

      // uid do documento deve ser o usuário autenticado
      && (request.resource.data.uid is string)
      && request.resource.data.uid == uid()

      // timestamps: tipo (o "server time" é forçado no allow create/update)
      && optTimestamp("createdAt")
      && optTimestamp("updatedAt")

      // nickname + normalized coerentes
      && nicknameCoherent()
      && optStringSized("nickname", 3, 40)
       && (
        !hasField("nicknameNormalized")
        || request.resource.data.nicknameNormalized == null
        || (
          request.resource.data.nicknameNormalized is string
          && request.resource.data.nicknameNormalized
            .matches('^[a-z0-9._-]{3,40}$')
        )
      )

      // URLs (opcionais)
      && optUrl("avatarUrl", 1024)
      && optUrl("photoURL", 1024)

      // geo (opcional) + coerência + ranges
      && geoCoherent()
      && optNumberInRange("latitude", -90, 90)
      && optNumberInRange("longitude", -180, 180)
      && optGeohash("geohash")

      // campos textuais opcionais
      && optStringSized("municipio", 1, 80)
      && optStringSized("estado", 1, 40)
      && optStringSized("gender", 1, 40)
      && optStringSized("orientation", 1, 40)

      // role: criação força "free" e update impede mudança pelo cliente
      && optStringSized("role", 3, 20);
  }

  // -----------------------------------------------------------------------
  // CREATE
  // - somente dono
  // - createdAt/updatedAt obrigatoriamente serverTimestamp() => request.time
  // - role inicial obrigatoriamente "free"
  // -----------------------------------------------------------------------
  allow create: if (
    isSelf(userId)
    && validPublicProfilePayload()
    && request.resource.data.createdAt == request.time
    && request.resource.data.updatedAt == request.time
    && request.resource.data.role == "free"
  );

 // -----------------------------------------------------------------------
  // UPDATE
  // - somente dono
  // - uid e createdAt imutáveis
  // - updatedAt obrigatoriamente serverTimestamp() => request.time
  // - role imutável (anti auto-elevação)
  // -----------------------------------------------------------------------
  allow update: if (
    isSelf(userId)
    && validPublicProfilePayload()
    && request.resource.data.uid == resource.data.uid
    && request.resource.data.createdAt == resource.data.createdAt
    && request.resource.data.updatedAt == request.time
    && request.resource.data.role == resource.data.role
  );

  // Delete bloqueado
  allow delete: if false;
}

// ===== public_profiles_photos.rules =====
// firestore-rules/public_profiles_photos.rules
// ===============================================================
// PUBLIC_PROFILES / public_photos
// ===============================================================

match /public_profiles/{userId}/public_photos/{photoId} {

  function photoPath() {
    return /databases/$(database)/documents/public_profiles/$(userId)/public_photos/$(photoId);
  }

  function photoExists() {
    return exists(photoPath());
  }

  function photoData() {
    return get(photoPath()).data;
  }

  function isApprovedPublicPhotoData(data) {
    return data.visibility == "PUBLIC"
      && data.moderationStatus == "APPROVED";
  }

  function isPublicReadable() {
    return resource.data.visibility == "PUBLIC"
      && resource.data.moderationStatus == "APPROVED";
  }

  allow get: if signedIn() && (isSelf(userId) || isPublicReadable());

  allow list: if signedIn()
    && resource.data.visibility == "PUBLIC"
    && resource.data.moderationStatus == "APPROVED";

  allow create, update, delete: if false;

  match /likes/{viewerUid} {
    allow get: if signedIn() && request.auth.uid == viewerUid;
    allow list: if false;
    allow create, update, delete: if false;
  }

  match /comments/{commentId} {
    allow get: if signedIn()
      && (
        isSelf(userId)
        || (
          resource.data.status == "VISIBLE"
          && photoExists()
          && isApprovedPublicPhotoData(photoData())
        )
      );

    allow list: if signedIn()
      && (
        isSelf(userId)
        || (
          resource.data.status == "VISIBLE"
          && photoExists()
          && isApprovedPublicPhotoData(photoData())
        )
      );

    allow create, update, delete: if false;
  }
}

// ------------------------------------------------------------
// Collection group: public_photos
// Necessário para queries globais de Descobrir, Top, Últimas e Turbo.
// ------------------------------------------------------------
match /{path=**}/public_photos/{photoId} {
  allow list: if signedIn()
    && resource.data.visibility == "PUBLIC"
    && resource.data.moderationStatus == "APPROVED";

  allow get: if signedIn()
    && resource.data.visibility == "PUBLIC"
    && resource.data.moderationStatus == "APPROVED";

  allow create, update, delete: if false;
}

// ==============================================================
//           FIM DO PUBLIC_PROFILES_PHOTOS.RULES
// ==============================================================

// ===== presence.rules =====
// firestore-rules/presence.rules
// =========================================================================
// PRESENCE (efêmero / realtime)
//
// Objetivo (custo/benefício):
// - Bloquear LIST/QUERY de presença para requesters NÃO verificados.
// - Manter GET do próprio doc permitido (debug/telemetria do dono).
//
// Por que NÃO validar "targetEligible" aqui?
// - Para list/query seria necessário cross-document get() por doc retornado,
//   o que torna as rules pesadas e propensas a limite/custo.
// - A elegibilidade do ALVO fica no app (AccessControlService) por enquanto.
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
// =========================================================================

match /presence/{presenceUid} {

  // Requester precisa ter email verificado no token do Auth
  function requesterEmailVerified() {
    return signedIn() && request.auth.token.email_verified == true;
  }

  // -------------------------------------------------------------------------
  // READ
  // -------------------------------------------------------------------------

  // GET:
  // - dono pode ler o próprio doc (mesmo não verificado) para debug/telemetria
  // - terceiros: apenas se requester verificado
  allow get: if signedIn() && (
    isSelf(presenceUid) || requesterEmailVerified()
  );

  // LIST/QUERY:
  // - apenas requesters verificados podem consultar presença
  allow list: if requesterEmailVerified();

  // -------------------------------------------------------------------------
  // Helpers SAFE (writes)
  // -------------------------------------------------------------------------
  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function reqString(field) {
    return hasField(field) && request.resource.data[field] is string;
  }

  function reqBool(field) {
    return hasField(field) && request.resource.data[field] is bool;
  }

  function reqTimestamp(field) {
    return hasField(field) && isTs(request.resource.data[field]);
  }

  function reqEnum(field, allowed) {
    return hasField(field)
      && request.resource.data[field] is string
      && request.resource.data[field] in allowed;
  }

  // Whitelist rígida
  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "uid",
      "presenceSessionId",

      "isOnline",
      "presenceState",

      "lastSeen",
      "updatedAt",

      "lastStateChangeAt",
      "lastOnlineAt",
      "lastOfflineAt",

      "nickname",
      "municipio",
      "estado",
      "photoURL",
      "latitude",
      "longitude"
    ]);
  }

  // Documento final precisa estar íntegro
  function validPresencePayload() {
    return allowedKeys()

      // dono
      && reqString("uid")
      && request.resource.data.uid == uid()

      // sessão/aba
      && reqString("presenceSessionId")

      // estado
      && reqBool("isOnline")
      && reqEnum("presenceState", ["online", "away", "offline"])

      // telemetria base
      && reqTimestamp("lastSeen")

      // demais timestamps opcionais
      && optTimestamp("updatedAt")
      && optTimestamp("lastStateChangeAt")
      && optTimestamp("lastOnlineAt")
      && optTimestamp("lastOfflineAt")

      // campos públicos opcionais
      && optString("nickname")
      && optString("municipio")
      && optString("estado")
      && optString("photoURL")
      && optNumberOrNull("latitude")
      && optNumberOrNull("longitude");
  }

  // -------------------------------------------------------------------------
  // WRITE
  // -------------------------------------------------------------------------
  allow create, update: if (
    isSelf(presenceUid)
    && validPresencePayload()
  );

  allow delete: if false;
}
// ================================================================
                        // FIM DO PRESENCE.RULES
// ================================================================

// ===== regional_hot_places.rules =====
// firestore-rules/regional_hot_places.rules
// ============================================================================
// REGIONAL HOT PLACES / LOCAIS BOMBANDO
// ============================================================================
// Projeção agregada e moderada para exibição regional.
//
// Segurança:
// - leitura exige login;
// - leitura pública do app só para documentos visíveis;
// - escrita direta pelo cliente comum é bloqueada;
// - escrita administrativa exige claim admin;
// - documentos não devem carregar UIDs, participantes ou coordenadas precisas.
//
// Observação:
// - a UI consulta com where('moderation.visibility', '==', 'visible');
// - a geração de score deve vir de backend/admin, não do cliente comum.
// ============================================================================
match /regional_hot_places/{placeId} {
  function isVisibleHotPlace() {
    return resource.data.moderation.visibility == "visible";
  }

  allow get, list: if signedIn() && isVisibleHotPlace();

  allow create, update: if isAdmin() && validHotPlacePayload();
  allow delete: if isAdmin();

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "title",
      "subtitle",
      "kind",
      "audience",
      "region",
      "metrics",
      "moderation",
      "compatibilitySignals",
      "createdAt",
      "updatedAt"
    ]);
  }

  function optStringSized(field, min, max) {
    return !hasField(field)
      || request.resource.data[field] == null
      || (request.resource.data[field] is string
        && request.resource.data[field].size() >= min
        && request.resource.data[field].size() <= max);
  }

  function validRegion() {
    return request.resource.data.region is map
      && request.resource.data.region.keys().hasOnly(["uf", "city"])
      && request.resource.data.region.uf is string
      && request.resource.data.region.uf.matches('^[A-Z]{2}$')
      && request.resource.data.region.city is string
      && request.resource.data.region.city.size() >= 1
      && request.resource.data.region.city.size() <= 80;
  }

  function validMetrics() {
    return request.resource.data.metrics is map
      && request.resource.data.metrics.keys().hasOnly([
        "score",
        "activeNowCount",
        "roomCount",
        "compatibleProfileCount",
        "lastActivityAt"
      ])
      && request.resource.data.metrics.score is number
      && request.resource.data.metrics.score >= 0
      && request.resource.data.metrics.score <= 100000
      && validOptionalMetricNumber("activeNowCount")
      && validOptionalMetricNumber("roomCount")
      && validOptionalMetricNumber("compatibleProfileCount")
      && validOptionalMetricTime("lastActivityAt");
  }

  function hasMetric(field) {
    return request.resource.data.metrics.keys().hasAny([field]);
  }

  function validOptionalMetricNumber(field) {
    return !hasMetric(field)
      || request.resource.data.metrics[field] == null
      || (request.resource.data.metrics[field] is number
        && request.resource.data.metrics[field] >= 0
        && request.resource.data.metrics[field] <= 1000000);
  }

  function validOptionalMetricTime(field) {
    return !hasMetric(field)
      || request.resource.data.metrics[field] == null
      || request.resource.data.metrics[field] is number
      || request.resource.data.metrics[field] is timestamp;
  }

  function validModeration() {
    return request.resource.data.moderation is map
      && request.resource.data.moderation.keys().hasOnly([
        "visibility",
        "reviewedAt",
        "reviewedBy",
        "reason"
      ])
      && request.resource.data.moderation.visibility in [
        "visible",
        "hidden",
        "moderation_hold"
      ]
      && validOptionalModerationTime("reviewedAt")
      && validOptionalModerationString("reviewedBy", 1, 128)
      && validOptionalModerationString("reason", 1, 240);
  }

  function hasModerationField(field) {
    return request.resource.data.moderation.keys().hasAny([field]);
  }

  function validOptionalModerationTime(field) {
    return !hasModerationField(field)
      || request.resource.data.moderation[field] == null
      || request.resource.data.moderation[field] is number
      || request.resource.data.moderation[field] is timestamp;
  }

  function validOptionalModerationString(field, min, max) {
    return !hasModerationField(field)
      || request.resource.data.moderation[field] == null
      || (request.resource.data.moderation[field] is string
        && request.resource.data.moderation[field].size() >= min
        && request.resource.data.moderation[field].size() <= max);
  }

  function validHotPlacePayload() {
    return allowedKeys()
      && request.resource.data.title is string
      && request.resource.data.title.size() >= 3
      && request.resource.data.title.size() <= 80
      && optStringSized("subtitle", 1, 160)
      && request.resource.data.kind in [
        "city_area",
        "venue",
        "event",
        "room_cluster",
        "online_pulse"
      ]
      && request.resource.data.audience in [
        "all",
        "singles",
        "couples",
        "verified",
        "subscribers"
      ]
      && validRegion()
      && validMetrics()
      && validModeration()
      && request.resource.data.compatibilitySignals is list
      && request.resource.data.compatibilitySignals.size() <= 12
      && optTimestamp("createdAt")
      && optTimestamp("updatedAt");
  }
}

// ===== friendRequests.rules =====
    // =========================================================================
    // FRIEND.REQUESTS.RULES
    // - Solicitações de amizade (privado)
    //
    // Modelo de segurança:
    // - Leitura: somente envolvidos na solicitação.
    // - Escrita: somente via Cloud Functions.
    //
    // Callables responsáveis:
    // - sendFriendRequest
    // - acceptFriendRequest
    // - cancelFriendRequest
    // - declineFriendRequest
    //
    // Motivo:
    // - o cliente Angular/web/mobile não deve criar, aceitar, recusar,
    //   cancelar ou apagar solicitações diretamente no Firestore;
    // - Cloud Functions usam Admin SDK, validam request.auth.uid,
    //   e-mail verificado, ownership, status pending e auditoria;
    // - isso reduz bypass, spam social e inconsistência de estado.
    //
    // ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
    // uso de helpers globais
    // =========================================================================
    match /friendRequests/{reqId} {
      allow read: if signedIn() &&
        (resource.data.requesterUid == uid() ||
         resource.data.targetUid == uid());

      allow create, update, delete: if false;
    }

    // ====================================================================
    //                        FIM DO FRIEND.REQUESTS.RULES
    // ====================================================================

// ===== friends_root.rules =====
// firestore-rules/friends_root.rules
// =========================================================================
// FRIENDS (coleção raiz) — se você usar friends/{key}
// - Read: somente envolvidos
// - Write: somente envolvidos (MVP)
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
// =========================================================================

match /friends/{friendId} {

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function participantsFrom(data) {
    return (data.keys().hasAny(["participants"]) && data.participants is list)
      ? data.participants
      : [];
  }

  function isParticipantData(data) {
    let parts = participantsFrom(data);
    return signedIn() && (uid() in parts);
  }

  allow get: if signedIn() && isParticipantData(resource.data);
  allow list: if false;

  allow create: if signedIn()
    && hasField("participants")
    && request.resource.data.participants is list
    && request.resource.data.participants.size() == 2
    && (uid() in request.resource.data.participants);

  allow update: if signedIn()
    && isParticipantData(resource.data)
    && isParticipantData(request.resource.data);

  allow delete: if false;
}

// ===== chats.rules =====
    // =======================================================================
    // CHATS DIRETOS
    // ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem
    //    `service cloud.firestore`
    //
    // Segurança desta versão:
    // - leitura permanece restrita aos participantes da conversa;
    // - criação de chat direto ocorre somente por Cloud Function confiável;
    // - atualização do documento de chat ocorre somente por backend confiável;
    // - criação de mensagens diretas ocorre somente por Cloud Function;
    // - cliente pode atualizar exclusivamente recibos de mensagens recebidas,
    //   respeitando transição progressiva de status.
    //
    // Supressões explícitas:
    // - removida criação client-side de chats;
    // - removida atualização client-side de lastMessage,
    //   otherParticipantDetails e timestamp;
    // - removida criação client-side de mensagens diretas.
    // =======================================================================
match /chats/{chatId} {
  function isChatParticipant() {
    return signedIn()
      && (uid() in resource.data.participants);
  }

  /**
   * Permite ao cliente ler somente conversas das quais participa.
   *
   * A consulta do frontend já utiliza:
   * where('participants', 'array-contains', uid)
   */
  allow read: if isChatParticipant();

  /**
   * Criação e alteração estrutural de chat direto permanecem exclusivas
   * das Cloud Functions confiáveis.
   */
  allow create, update, delete: if false;
}

    match /chats/{chatId}/messages/{messageId} {
      function chatExists() {
        return exists(/databases/$(database)/documents/chats/$(chatId));
      }

      function isChatParticipantByChat() {
        return signedIn()
          && chatExists()
          && get(/databases/$(database)/documents/chats/$(chatId)).data.participants is list
          && (
            uid() in get(
              /databases/$(database)/documents/chats/$(chatId)
            ).data.participants
          );
      }

      function isMessageReceivedByCurrentUser() {
        return (
          resource.data.keys().hasAny(["senderId"])
          && resource.data.senderId != uid()
        )
        || (
          resource.data.keys().hasAny(["senderUid"])
          && resource.data.senderUid != uid()
        );
      }

      function isForwardReceiptTransition() {
        return (
          resource.data.status == "sent"
          && request.resource.data.status == "delivered"
        )
        || (
          resource.data.status == "delivered"
          && request.resource.data.status == "read"
        );
      }

      /**
       * Leitura permanece disponível somente a participantes do chat.
       */
      allow read: if isChatParticipantByChat();

      /**
       * Mensagens diretas novas são gravadas apenas por sendDirectMessage.
       */
      allow create: if false;

      /**
       * Exceção temporária e estrita para recibos:
       * - somente participante;
       * - somente mensagem recebida;
       * - somente campo status;
       * - somente avanço sent -> delivered -> read.
       *
       * Em etapa futura, receipts também deverão migrar para backend.
       */
      allow update: if isChatParticipantByChat()
        && isMessageReceivedByCurrentUser()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status"
        ])
        && isForwardReceiptTransition();

      allow delete: if false;
    }

// ===== rooms.rules =====
// ================================================================
// ROOMS.RULES
// - Coleção raiz: rooms/{roomId}
// - Criação: somente backend confiável via callable createPrivateRoom
// - Leitura individual: somente participante/owner operacionalmente válido
// - Listagem: somente salas em que o usuário consta em participants[]
// - Entrada temporária: mantém aceite por convite ainda existente no cliente
// - Update estrutural direto: bloqueado
// - Delete direto: bloqueado
//
// Migração em andamento:
// - participants[] permanece apenas como projeção transitória consultável;
// - rooms/{roomId}/members/{uid} já nasce no backend;
// - a estrutura escalável futura deverá utilizar projeção por usuário,
//   mantida exclusivamente pelo backend;
// - convite/aceite serão migrados para Functions na próxima etapa.
//
// ARQUIVO MODULAR: não incluir rules_version nem service cloud.firestore.
// ================================================================

match /rooms/{roomId} {

  function actorUserPath() {
    return /databases/$(database)/documents/users/$(uid());
  }

  function actorUserExists() {
    return signedIn() && exists(actorUserPath());
  }

  function actorIsOperationallyActive() {
    return actorUserExists()
      && (
        !get(actorUserPath()).data.keys().hasAny(["accountStatus"])
        || get(actorUserPath()).data.accountStatus == "active"
      )
      && (
        !get(actorUserPath()).data.keys().hasAny(["interactionBlocked"])
        || get(actorUserPath()).data.interactionBlocked != true
      )
      && (
        !get(actorUserPath()).data.keys().hasAny(["accountLocked"])
        || get(actorUserPath()).data.accountLocked != true
      )
      && (
        !get(actorUserPath()).data.keys().hasAny(["loginAllowed"])
        || get(actorUserPath()).data.loginAllowed != false
      );
  }

  function actorCanInteract() {
    return actorIsOperationallyActive()
      && request.auth.token.email_verified == true
      && get(actorUserPath()).data.profileCompleted == true;
  }

  /**
   * Uso exclusivo em leitura individual e validações de atualização.
   *
   * Em get/update, a Rule pode avaliar concretamente o documento existente.
   */
  function participantsFrom(data) {
    return (
      data.keys().hasAny(["participants"])
      && data.participants is list
    )
      ? data.participants
      : [];
  }

  function isRoomParticipant() {
    return actorCanInteract()
      && (uid() in participantsFrom(resource.data));
  }

  function isRoomOwner() {
    return actorCanInteract()
      && resource.data.keys().hasAny(["createdBy"])
      && resource.data.createdBy == uid();
  }

  /**
   * Listagem compatível com a consulta frontend:
   *
   * where("participants", "array-contains", uid)
   * limit(30)
   *
   * Nesta condição não usamos participantsFrom(), porque consultas precisam
   * refletir diretamente o campo usado para restringir o conjunto potencial
   * de resultados.
   */
  function canListParticipatingRooms() {
    return actorCanInteract()
      && request.query.limit <= 30
      && (uid() in resource.data.participants);
  }

  // ------------------------------------------------------------
  // JOIN TEMPORÁRIO POR CONVITE EXISTENTE
  //
  // Esta passagem permanece somente até acceptRoomInvite ser migrada
  // para Function. O owner não pode adicionar terceiros diretamente.
  // ------------------------------------------------------------

  function joinInviteId() {
    return "room:" + roomId + ":to:" + uid();
  }

  function joinInvitePath() {
    return /databases/$(database)/documents/invites/$(joinInviteId());
  }

  function joinInviteExists() {
    return exists(joinInvitePath());
  }

  function joinInviteData() {
    return get(joinInvitePath()).data;
  }

  function joinInviteIsRoomType() {
    return !joinInviteData().keys().hasAny(["type"])
      || joinInviteData().type == "room";
  }

  function joinInviteTargetsThisRoom() {
    return (
      (
        joinInviteData().keys().hasAny(["targetId"])
        && joinInviteData().targetId == roomId
      )
      ||
      (
        joinInviteData().keys().hasAny(["roomId"])
        && joinInviteData().roomId == roomId
      )
    );
  }

  function hasPendingJoinInvite() {
    return actorCanInteract()
      && joinInviteExists()
      && joinInviteData().status == "pending"
      && joinInviteData().receiverId == uid()
      && joinInviteIsRoomType()
      && joinInviteTargetsThisRoom()
      && joinInviteData().expiresAt > request.time;
  }

  function isJoinUpdateShape() {
    let oldParticipants = participantsFrom(resource.data);

    return !(uid() in oldParticipants)
      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "participants",
        "lastActivity"
      ])
      && request.resource.data.participants is list
      && (uid() in request.resource.data.participants)
      && request.resource.data.participants.size() == oldParticipants.size() + 1
      && request.resource.data.participants.hasAll(oldParticipants)
      && request.resource.data.lastActivity == request.time;
  }

  /**
   * A leitura direta de uma sala específica continua aceitando:
   * - participante ativo;
   * - owner ativo.
   */
  allow get: if isRoomParticipant() || isRoomOwner();

  /**
   * A listagem é restrita à query de participação do usuário autenticado.
   * Não autoriza enumeração geral de salas nem consulta owner-only.
   */
  allow list: if canListParticipatingRooms();

  /**
   * Salas privadas nascem somente pela Function createPrivateRoom.
   * O Admin SDK usado pela Function não depende desta permissão.
   */
  allow create: if false;

  /**
   * Nenhum owner ou participante altera estrutura da sala diretamente.
   *
   * Mantemos apenas a entrada temporária do próprio destinatário de um
   * convite válido, pois RoomInviteFlowService ainda executa essa transação
   * no cliente. Esse fluxo ainda não é considerado final ou seguro.
   */
  allow update: if hasPendingJoinInvite() && isJoinUpdateShape();

  allow delete: if false;
}

// ----------------------------------------------------------------
// MODELO FUTURO DE MEMBERSHIP
//
// A callable createPrivateRoom já cria o owner em /members.
// Nenhum cliente deve escrever ou enumerar esta coleção nesta etapa.
// ----------------------------------------------------------------

match /rooms/{roomId}/members/{memberUid} {
  allow read, write: if false;
}

// ----------------------------------------------------------------
// COLEÇÕES INTERNAS DO BACKEND
// ----------------------------------------------------------------

match /room_owner_slots/{ownerUid} {
  allow read, write: if false;
}

match /room_audit/{auditId} {
  allow read, write: if false;
}
// ================================================================
// FIM DO ROOMS.RULES
// ================================================================

// ===== rooms_participants.rules =====
// ==================================================================
// ROOMS / participants (subcollection)
// - Read: participantes reais da sala OU owner da sala
// - Write:
//   - o próprio usuário pode criar/atualizar seu doc
//   - o owner da sala também pode criar/atualizar docs de participantes
// - Mantém a fonte de verdade principal em rooms/{roomId}.participants
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// firestore-rules/rooms_participants.rules
// ==================================================================
match /rooms/{roomId}/participants/{userId} {

  function roomPath() {
    return /databases/$(database)/documents/rooms/$(roomId);
  }

  function roomExists() {
    return exists(roomPath());
  }

  function roomData() {
    return get(roomPath()).data;
  }

  function roomParticipants() {
    return roomData().participants is list ? roomData().participants : [];
  }

  function isRoomOwnerRequester() {
    return signedIn()
      && roomExists()
      && roomData().createdBy == uid();
  }

  function isRoomParticipantRequester() {
    return signedIn()
      && roomExists()
      && (uid() in roomParticipants());
  }

  function canReadParticipantDocs() {
    return isRoomParticipantRequester() || isRoomOwnerRequester();
  }

  function canWriteParticipantDoc() {
    return isSelf(userId) || isRoomOwnerRequester();
  }

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "uid",
      "joinedAt",
      "removedAt",
      "removed"
    ]);
  }

  function optBool(field) {
    return !hasField(field)
      || request.resource.data[field] == null
      || request.resource.data[field] is bool;
  }

  function optNumberOrTimestamp(field) {
    return !hasField(field)
      || request.resource.data[field] == null
      || request.resource.data[field] is number
      || isTs(request.resource.data[field]);
  }

  function validPayload() {
    return allowedKeys()
      && request.resource.data.uid == userId
      && optNumberOrTimestamp("joinedAt")
      && optNumberOrTimestamp("removedAt")
      && optBool("removed");
  }

  allow get, list: if canReadParticipantDocs();

  allow create, update: if
    roomExists()
    && canWriteParticipantDoc()
    && validPayload();

  allow delete: if false;
}
// ================================================================
//               FIM DO ROOMS_PARTICIPANTS.RULES
// ================================================================

// ===== public_index.rules =====
    // =======================================================================
    // PUBLIC INDEX (índice técnico)
    // ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
    // uso de helpers globais
    // entretenimento\firestore-rules\public_index.rules
    // =======================================================================
match /public_index/{docId} {
  function isNicknameDoc() { return docId.matches('^nickname:.+'); }
  function isEmailDoc() { return docId.matches('^email:.+'); }

  allow get: if isNicknameDoc()
    || (signedIn() && isEmailDoc() && resource.data.uid == uid());

  allow list: if false;

  function validDocId() { return isNicknameDoc() || isEmailDoc(); }

  function common() {
    return signedIn()
      && validDocId()
      && request.resource.data.uid == uid()
      && request.resource.data.type in ["nickname","email"]
      && request.resource.data.value is string
      // ✅ serverTimestamp obrigatório
      && request.resource.data.createdAt == request.time
      && request.resource.data.lastChangedAt == request.time;
  }

  allow create: if common()
    && !exists(/databases/$(database)/documents/public_index/$(docId));

  allow update: if signedIn()
    && isEmailDoc()
    && request.resource.data.uid == uid()
    && request.resource.data.type == "email"
    && request.resource.data.value is string
    && request.resource.data.createdAt == resource.data.createdAt
    // ✅ serverTimestamp obrigatório no update
    && request.resource.data.lastChangedAt == request.time;

  allow delete: if signedIn() && resource.data.uid == uid();
}

// ===== users_profile_socialLinks.rules =====

// ===============================================================
// USERS / profileData / socialLinks (privado)
// - Fonte de verdade
// - Escrita: somente dono
// - Leitura: somente dono (padrão). Moderador/admin opcional.
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
// C:\entretenimento\firestore-rules\users_profile_socialLinks.rules
// ===============================================================
match /users/{userId}/profileData/socialLinks {

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "facebook","instagram","twitter","linkedin","youtube","tiktok","snapchat",
      "sexlog","d4swing",

      // ✅ novo + sugestões
      "hotvips",
      "privacy",
      "onlyfans",
      "fansly",
      "linktree"
    ]);
  }

  function validPayload() {
    return allowedKeys()
      && optString("facebook")
      && optString("instagram")
      && optString("twitter")
      && optString("linkedin")
      && optString("youtube")
      && optString("tiktok")
      && optString("snapchat")
      && optString("sexlog")
      && optString("d4swing")

      // ✅ novo + sugestões
      && optString("hotvips")
      && optString("privacy")
      && optString("onlyfans")
      && optString("fansly")
      && optString("linktree");
  }

  allow get: if isSelf(userId);
  allow create: if isSelf(userId) && validPayload();
  allow update: if isSelf(userId) && validPayload();
  allow list: if false;
  allow delete: if false;
}
// ===============================================================
//                    FIM DO SOCIAL.LINKS
// ===============================================================

// ===== public_social_links.rules =====
// ===============================================================
// PUBLIC SOCIAL LINKS (espelho público)
// - Somente subset publicado
// - Escrita: somente dono
// - Leitura: exige login (alinhado ao seu /public_profiles)
// - Evita LIST (padrão anti-scraping)
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`.
// uso de helpers globais
// C:\entretenimento\firestore-rules\public_social_links.rules
// ===============================================================
match /public_social_links/{userId} {

  allow get: if signedIn();
  allow list: if false;

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "uid",
      "facebook","instagram","twitter","linkedin","youtube","tiktok","snapchat",
      "sexlog","d4swing",

      // ✅ novo + sugestões
      "hotvips",
      "privacy",
      "onlyfans",
      "fansly",
      "linktree",

      "updatedAt"
    ]);
  }

  function validPayload() {
    return request.resource.data.uid == uid()
      && allowedKeys()
      && optString("facebook")
      && optString("instagram")
      && optString("twitter")
      && optString("linkedin")
      && optString("youtube")
      && optString("tiktok")
      && optString("snapchat")
      && optString("sexlog")
      && optString("d4swing")

      // ✅ novo + sugestões
      && optString("hotvips")
      && optString("privacy")
      && optString("onlyfans")
      && optString("fansly")
      && optString("linktree")

      && optTimestamp("updatedAt");
  }

  allow create: if isSelf(userId)
    && validPayload()
    && request.resource.data.updatedAt == request.time;

  allow update: if isSelf(userId)
    && validPayload()
    && request.resource.data.uid == resource.data.uid
    && request.resource.data.updatedAt == request.time
    && request.resource.data.diff(resource.data).changedKeys().hasOnly([
      "facebook","instagram","twitter","linkedin","youtube","tiktok","snapchat",
      "sexlog","d4swing",

      // ✅ novo + sugestões
      "hotvips",
      "privacy",
      "onlyfans",
      "fansly",
      "linktree",

      "updatedAt"
    ]);

  allow delete: if isSelf(userId);
}
// ===============================================================
                   // FIM PUBLIC SOCIAL LINKS
// ===============================================================

// ===== preferences.rules =====
// =========================================================================
// PREFERENCES.RULES
// - Preferências do usuário (privado)
// - Regra segura: só o dono lê/escreve
// - Usa helpers já definidos em _helpers.rules: signedIn(), uid(), isSelf()
// firestore-rules/preferences.rules
// Observação importante:
// - Evita LIST/QUERY para não expor preferências de outros usuários
// - Se precisar de list/query, considere criar uma coleção separada com regras específicas
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
// =========================================================================

match /preferences/{userId} {
  allow get: if isSelf(userId);
  allow list: if false;              // evita enumeração

  allow create, update: if isSelf(userId);
  allow delete: if false;
}

match /users/{userId}/preferences/{docId} {
  allow get, list: if isSelf(userId); // aqui list faz sentido (vários docs do dono)
  allow create, update: if isSelf(userId);
  allow delete: if false;
}
// =========================================================================
//                        FIM DO PREFERENCES.RULES
// =========================================================================
// não esquecer de ajustar o build-firestore-rules.mjs para incluir este arquivo
// não esquecer de testar as regras com o emulador ou no console do Firebase
// não esquecer de documentar as preferências usadas no app (ex: README ou wiki)
// não esquecer de tratar erros de permissão no app (ex: exibir mensagem amigável)
// não esquecer de validar os dados no app antes de gravar no Firestore
// não esquecer de considerar criptografia se houver dados sensíveis nas preferências
// não esquecer de revisar as regras periodicamente conforme o app evolui
// não esquecer de monitorar acessos negados no Firebase Console (logs de segurança)
// não esquecer de ajustar índices compostos se usar consultas complexas nas preferências
// não esquecer de otimizar o tamanho dos documentos de preferências para evitar custos excessivos
// não esquecer de considerar limites de taxa do Firestore se o app tiver muitos usuários
// não esquecer de usar cache local no app para melhorar performance ao ler preferências
// não esquecer de tratar migrações de preferências se o esquema mudar no futuro
// não esquecer de comunicar aos usuários sobre como suas preferências são armazenadas e usadas
// não esquecer de seguir as melhores práticas de segurança do Firebase Firestore
// não esquecer de testar com diferentes níveis de autenticação (usuário, admin, etc.
// não esquecer de usar o Firebase Emulator Suite para testes locais
// não esquecer de revisar as regras com a equipe de segurança se aplicável
// não esquecer de versionar as regras se o Firebase suportar no futuro
// não esquecer de documentar qualquer dependência entre preferências e outras partes do app
// não esquecer de considerar o uso de funções do Firebase para lógica complexa relacionada a preferências
// não esquecer de validar o tamanho máximo dos documentos de preferências
// não esquecer de considerar a privacidade dos dados conforme leis aplicáveis (ex: GDPR, LGPD)
// não esquecer de definir quais campos são obrigatórios ou opcionais nas preferências
// não esquecer de fefinir padrões para preferências não definidas pelos usuários
// não esquecer de considerar a internacionalização se o app for multilíngue
// não esquecer de revisar o uso de preferências no app para evitar acessos desnecessários
// não esquecer de definir o que pode ser acessado anonimamente, se aplicável
// não esquecer o que deve ser diponibilizado apenas para usuários autenticados
// não esquecer de considerar o uso de claims personalizados se houver níveis diferentes de acesso
// não esquecer de definir as preferencias do usuário que só podem ser acessadas por ele mesmo ou administradores

// ===== users_friends.rules =====
//==============================================================================
// Regras de segurança do Firestore para a coleção de amigos dos usuários.
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
//==============================================================================
match /users/{userId}/friends/{friendUid} {
  // List/query da lista de amigos
  allow get, list: if isSelf(userId);

  // MVP: o dono mantém seu índice
  allow create, update, delete: if isSelf(userId);
}
// ==============================================================
//                 FIM DO USERS_FRIENDS.RULES
// ==============================================================

// ===== user_profile.rules =====
// firestore-rules/user_profile.rules
// =========================================================================
// USER_PROFILE (raiz) — privado, MVP
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
// =========================================================================

match /user_profile/{userId} {
  allow get, list: if isSelf(userId);
  allow create, update: if isSelf(userId);
  allow delete: if false;
}

// ===== users_photos.rules =====
// ===============================================================
// USERS / photos + imageStates + comments
// - Fluxo atual: metadado da foto salva id, url, path, fileName, createdAt
// - Somente o dono lê/escreve
// - displayDate é metadado privado de organização e só pode ser alterado por assinantes
// - Sem scraping, sem enumeração
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
// firestore-rules/users_photos.rules
// 14ABR2026
// ===============================================================
match /users/{userId}/photos/{photoId} {

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function userDoc() {
    return get(/databases/$(database)/documents/users/$(userId)).data;
  }

  function hasPaidPhotoDateAccess() {
    let user = userDoc();
    return user.monthlyPayer == true
      && user.subscriptionStatus == "active"
      && (
        user.role == "basic" ||
        user.role == "premium" ||
        user.role == "vip" ||
        user.role == "admin"
      );
  }

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "id",
      "url",
      "path",
      "fileName",
      "createdAt",
      "displayDate",
      "updatedAt"
    ]);
  }

  function validDisplayDate() {
    return !hasField("displayDate")
      || request.resource.data.displayDate == null
      || (
        request.resource.data.displayDate is number
        && request.resource.data.displayDate >= 0
        && request.resource.data.displayDate <= 4133980799999
      );
  }

  function displayDateCreateAllowed() {
    return !hasField("displayDate")
      || request.resource.data.displayDate == null
      || hasPaidPhotoDateAccess();
  }

  function displayDateUpdateAllowed() {
    return !request.resource.data.diff(resource.data).changedKeys().hasAny(["displayDate"])
      || hasPaidPhotoDateAccess();
  }

  function validPhotoPayload() {
    return allowedKeys()
      && (!hasField("id") || request.resource.data.id is string)
      && (!hasField("url") || request.resource.data.url is string)
      && (!hasField("path") || request.resource.data.path is string)
      && (!hasField("fileName") || request.resource.data.fileName is string)
      && optTimestamp("createdAt")
      && validDisplayDate()
      && optTimestamp("updatedAt");
  }

  allow get, list: if isSelf(userId);

  allow create: if isSelf(userId)
    && validPhotoPayload()
    && displayDateCreateAllowed();

  allow update: if isSelf(userId)
    && validPhotoPayload()
    && displayDateUpdateAllowed();

  allow delete: if isSelf(userId);

  match /comments/{commentId} {
    function allowedCommentKeys() {
      return request.resource.data.keys().hasOnly(["comment", "date"]);
    }

    function validCommentPayload() {
      return allowedCommentKeys()
        && request.resource.data.comment is string
        && optTimestamp("date");
    }

    allow get, list: if isSelf(userId);
    allow create: if isSelf(userId) && validCommentPayload();
    allow update, delete: if false;
  }
}

// -------------------------------------------------------------------------
// imageStates (subcollection) — MVP: só dono
// -------------------------------------------------------------------------
match /users/{userId}/imageStates/{stateId} {
  function allowedKeys() {
    return request.resource.data.keys().hasOnly(["imageState", "createdAt"]);
  }

  function validPayload() {
    return allowedKeys()
      && request.resource.data.imageState is string
      && optTimestamp("createdAt");
  }

  allow get, list: if isSelf(userId);
  allow create: if isSelf(userId) && validPayload();
  allow update, delete: if false;
}
// ===============================================================
//                   FIM DO PHOTOS + IMAGESTATES
// ===============================================================

// ===== users_photo_publications.rules =====
// firestore-rules/users_photo_publications.rules
// ==============================================================
// USERS / photo_publications
//
// Configuração privada de publicação das fotos.
// O dono pode ler e solicitar configuração, mas campos estratégicos
// precisam ser bem controlados.
//
// Observação:
// - Esta regra ainda permite o dono escrever configuração de publicação.
// - Para produção, o ideal é mover publish/unpublish/moderação/score para
//   Cloud Functions auditadas.
// ==============================================================

match /users/{userId}/photo_publications/{photoId} {

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function optBool(field) {
    return !hasField(field)
      || request.resource.data[field] == null
      || request.resource.data[field] is bool;
  }

  function optNumber(field) {
    return !hasField(field)
      || request.resource.data[field] == null
      || request.resource.data[field] is number;
  }

  function optStringOrNull(field) {
    return !hasField(field)
      || request.resource.data[field] == null
      || request.resource.data[field] is string;
  }

  function validVisibility() {
    return hasField("visibility")
      && request.resource.data.visibility in [
        "PRIVATE",
        "FRIENDS",
        "SUBSCRIBERS",
        "PREMIUM",
        "PUBLIC"
      ];
  }

  function validCommentsPolicy() {
    return !hasField("commentsPolicy")
      || request.resource.data.commentsPolicy in [
        "OFF",
        "FRIENDS",
        "SUBSCRIBERS",
        "EVERYONE"
      ];
  }

  function validModerationStatus() {
    return !hasField("moderationStatus")
      || request.resource.data.moderationStatus in [
        "PRIVATE",
        "PENDING_REVIEW",
        "APPROVED",
        "REJECTED",
        "FLAGGED",
        "HIDDEN"
      ];
  }

  function validScoreBreakdown() {
    return !hasField("scoreBreakdown")
      || (
        request.resource.data.scoreBreakdown is map
        && request.resource.data.scoreBreakdown.keys().hasOnly([
          "rankingScore",
          "qualityScore",
          "engagementScore",
          "safetyScore"
        ])
        && request.resource.data.scoreBreakdown.rankingScore is number
        && request.resource.data.scoreBreakdown.qualityScore is number
        && request.resource.data.scoreBreakdown.engagementScore is number
        && request.resource.data.scoreBreakdown.safetyScore is number
      );
  }

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "photoId",
      "ownerUid",

      "isPublished",
      "visibility",
      "isCover",
      "orderIndex",

      "commentsEnabled",
      "commentsPolicy",
      "commentsCount",

      "reactionsEnabled",
      "reactionsCount",

      "moderationStatus",
      "moderationReason",
      "reportsCount",

      "score",
      "scoreBreakdown",

      "publishedAt",
      "updatedAt",
      "lastModeratedAt"
    ]);
  }

  function validPayload() {
    return allowedKeys()
      && request.resource.data.photoId == photoId
      && request.resource.data.ownerUid == userId

      && optBool("isPublished")
      && validVisibility()
      && optBool("isCover")
      && optNumber("orderIndex")

      && optBool("commentsEnabled")
      && validCommentsPolicy()
      && optNumber("commentsCount")

      && optBool("reactionsEnabled")
      && optNumber("reactionsCount")

      && validModerationStatus()
      && optStringOrNull("moderationReason")
      && optNumber("reportsCount")

      && optNumber("score")
      && validScoreBreakdown()

      && optNumber("publishedAt")
      && optNumber("updatedAt")
      && optNumber("lastModeratedAt");
  }

  allow get, list: if isSelf(userId);

  allow create, update: if isSelf(userId)
    && validPayload();

  allow delete: if isSelf(userId);
}
// ==============================================================
//           FIM DO USERS_PHOTO_PUBLICATIONS.RULES
// ==============================================================

// ===== users_blocks.rules =====
// =========================================================================
// USERS / blocks (privado) + events (auditoria)
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
// firestore-rules/users_blocks.rules
// =========================================================================

match /users/{ownerUid}/blocks/{targetUid} {

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      "uid",
      "isBlocked",
      "blockedAt",
      "unblockedAt",
      "reason",
      "actorUid",
      "updatedAt"
    ]);
  }

  function validPayload() {
    return allowedKeys()
      && request.resource.data.uid == targetUid
      && request.resource.data.actorUid == ownerUid
      && reqBoolOrOpt("isBlocked")
      && optTimestamp("blockedAt")
      && optTimestamp("unblockedAt")
      && optString("reason")
      && optTimestamp("updatedAt");
  }

  function reqBoolOrOpt(field) {
    return !hasField(field) || request.resource.data[field] is bool;
  }

  allow get, list: if isSelf(ownerUid);
  allow create, update, delete: if isSelf(ownerUid) && validPayload();

  // -----------------------------------------------------------------------
  // events
  // -----------------------------------------------------------------------
  match /events/{eventId} {
    function allowedEventKeys() {
      return request.resource.data.keys().hasOnly([
        "type",
        "actorUid",
        "targetUid",
        "reason",
        "createdAt"
      ]);
    }

    function validEventPayload() {
      return allowedEventKeys()
        && request.resource.data.actorUid == ownerUid
        && request.resource.data.targetUid == targetUid
        && request.resource.data.type in ["block","unblock"]
        && optString("reason")
        && isTs(request.resource.data.createdAt);
    }

    allow get, list: if isSelf(ownerUid);
    allow create: if isSelf(ownerUid) && validEventPayload();
    allow update, delete: if false;
  }
}

// ===== communities.rules =====
// firestore-rules/communities.rules
// =========================================================================
// COMMUNITIES (MVP)
// - Read: signedIn (produto normalmente precisa discovery)
// - Write: apenas creator (createdBy == uid)
// - Sem list pública: aqui deixei list liberado p/ signedIn (ajuste se quiser anti-scraping)
//✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
// =========================================================================

match /communities/{communityId} {

  function isOwner() {
    return signedIn()
      && resource.data.keys().hasAny(["createdBy"])
      && resource.data.createdBy == uid();
  }

  function allowedKeys() {
    // MVP: não travar demais para não quebrar seu addDoc atual
    // mas ainda evita keys absurdas caso você queira.
    // Se quiser schema rígido depois, a gente endurece.
    return true;
  }

  allow get, list: if signedIn();

  allow create: if signedIn()
    && request.resource.data.keys().hasAny(["createdBy"])
    && request.resource.data.createdBy == uid()
    && allowedKeys();

  allow update: if isOwner()
  && request.resource.data.keys().hasAny(["createdBy"])
  && request.resource.data.createdBy == resource.data.createdBy
  && allowedKeys();

  allow delete: if false;
}
// ================================================================
                        // FIM DO COMMUNITIES.RULES
// ================================================================

// ===== invites.rules =====
// ================================================================
//                INVITES.RULES (coleção raiz)
// - Read: sender ou receiver
// - Create: sender cria pending
// - Update:
//   - receiver aceita/recusa
//   - sender pode expirar (opcional)
// - Delete: sender pode apagar enquanto pending (opcional)
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`
// uso de helpers globais
// firestore-rules/invites.rules
// ================================================================
match /invites/{inviteId} {

  function isSender() {
    return signedIn() && resource.data.senderId == uid();
  }

  function isReceiver() {
    return signedIn() && resource.data.receiverId == uid();
  }

  function hasField(field) {
    return request.resource.data.keys().hasAny([field]);
  }

  function allowedKeys() {
    return request.resource.data.keys().hasOnly([
      // v2
      "type",
      "targetId",
      "targetName",

      // canônico
      "senderId",
      "receiverId",
      "status",
      "sentAt",
      "expiresAt",

      // audit
      "respondedAt",
      "updatedAt",

      // legacy (room)
      "roomId",
      "roomName"
    ]);
  }

  function isV2() {
    return hasField("type") && hasField("targetId");
  }

  function validCreateV2() {
    return allowedKeys()
      && request.resource.data.senderId == uid()
      && request.resource.data.receiverId is string
      && request.resource.data.receiverId != uid()
      && request.resource.data.type in ["room", "community", "friend"]
      && request.resource.data.targetId is string
      && request.resource.data.status == "pending"
      && isTs(request.resource.data.sentAt)
      && isTs(request.resource.data.expiresAt)
      // audit opcional no create (recomendado)
      && (!hasField("updatedAt") || request.resource.data.updatedAt == request.time)
      && (!hasField("respondedAt") || request.resource.data.respondedAt == null);
  }

  function validCreateLegacyRoom() {
    // mantém compat para payload antigo (se ainda existir)
    return allowedKeys()
      && request.resource.data.senderId == uid()
      && request.resource.data.receiverId is string
      && request.resource.data.receiverId != uid()
      && request.resource.data.roomId is string
      && request.resource.data.status == "pending"
      && isTs(request.resource.data.sentAt)
      && isTs(request.resource.data.expiresAt)
      && (!hasField("updatedAt") || request.resource.data.updatedAt == request.time)
      && (!hasField("respondedAt") || request.resource.data.respondedAt == null);
  }

  // READ
  allow get: if signedIn() && (isSender() || isReceiver());

  // ✅ necessário para inbox (query). Segurança real continua no get/read por doc.
  allow list: if signedIn() && (isSender() || isReceiver());

  // CREATE
  allow create: if signedIn() && (validCreateV2() || validCreateLegacyRoom());

  // UPDATE (status machine + audit)
  allow update: if signedIn()
    && resource.data.status == "pending"
    && request.resource.data.status != resource.data.status
    && request.resource.data.diff(resource.data).changedKeys().hasOnly([
      "status",
      "respondedAt",
      "updatedAt"
    ])
    && (
      // receiver aceita/declina
      (isReceiver()
        && request.resource.data.status in ["accepted", "declined"]
        && request.resource.data.respondedAt == request.time
        && request.resource.data.updatedAt == request.time
      )
      ||
      // sender expira/cancela
      (isSender()
        && request.resource.data.status in ["expired", "canceled"]
        && request.resource.data.updatedAt == request.time
        && (!("respondedAt" in request.resource.data) || request.resource.data.respondedAt == resource.data.respondedAt)
      )
      ||
      // admin (se quiser manter)
      (isAdmin() == true)
    );

  // DELETE (mantém seu MVP)
  allow delete: if signedIn() && isSender() && resource.data.status == "pending";
}
// ================================================================
//                        FIM DO INVITES.RULES
// ================================================================

// ===== admin_logs.rules =====
// firestore-rules/admin_logs.rules
// =========================================================================
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`.
// ADMIN LOGS (auditoria / staff)
// - Somente staff (admin/moderator) pode criar
// - Leitura: restrita (get) para staff
// - Sem list (anti-enumeração)
// - Sem update/delete (log imutável)
// - timestamp obrigatório via serverTimestamp() => request.time
// =========================================================================
match /admin_logs/{logId} {
  function isAdminActor() { return isAdmin(); }

  allow get: if isAdminActor();
  allow list: if isAdminActor();

  allow create: if isAdminActor()
    && request.resource.data.keys().hasOnly([
      "adminUid","action","targetUserUid","details","timestamp"
    ])
    && request.resource.data.adminUid == uid()
    && request.resource.data.action is string
    && request.resource.data.targetUserUid is string
    && request.resource.data.timestamp == request.time; // força server time

  allow update, delete: if false;
}

// ===== _footer.rules =====
// ===============================================================
//                            _FOOTER.RULES
//C:\entretenimento\firestore-rules\_footer.rules
// ✅ ARQUIVO MODULAR: NÃO pode ter `rules_version` nem `service cloud.firestore`.
// Este arquivo é o "rodapé" das regras do Firestore. Ele é importado no final do arquivo principal de regras (ex: firestore.rules) para garantir que as regras sejam fechadas corretamente
// ===============================================================
  }
}
// ===============================================================
//                             FIM DO _FOOTER.RULES
//                            FIM DO FIRESTORE RULES
// Final do arquivo de regras do Firestore. Se precisar de novas regras,
// crie um novo arquivo .rules e importe aqui.
// ================================================================
