{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "src/**/*.test.ts",
        "lib/**/*.test.js",
        "lib/**/*.test.js.map"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "singleProjectMode": true,
    "ui": {
      "enabled": false
    },
    "hub": {
      "host": "127.0.0.1",
      "port": 14410
    },
    "logging": {
      "host": "127.0.0.1",
      "port": 14510
    },
    "auth": {
      "host": "127.0.0.1",
      "port": 19099
    },
    "firestore": {
      "host": "127.0.0.1",
      "port": 18080
    },
    "functions": {
      "host": "127.0.0.1",
      "port": 15001
    },
    "storage": {
      "host": "127.0.0.1",
      "port": 19199
    }
  }
}
