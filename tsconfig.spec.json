{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": [
      "vitest/globals",
      "node"
    ],
    "emitDecoratorMetadata": false,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "@app/*": ["src/app/*"],
      "@core/*": ["src/app/core/*"],
      "@shared/*": ["src/app/shared/*"],
      "@env/*": ["src/environments/*"],
      "@store/*": ["src/app/store/*"]
    }
  },
  "files": [
    "src/test/setup-vitest.ts"
  ],
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "src/test/setup-vitest.ts",
    "src/test/jest-stubs/**/*.ts"
  ],
  "exclude": [
    "src/test/setup-jest.ts"
  ]
}