{
  "name": "functions",
  "private": true,
  "type": "commonjs",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "lint": "eslint -c eslint.config.js \"src/**/*.ts\"",
    "lint:fix": "eslint -c eslint.config.js \"src/**/*.ts\" --fix",
    "lint:deploy": "eslint -c eslint.config.js \"src/index.ts\" \"src/community/**/*.ts\" \"src/discovery/**/*.ts\" \"src/chat/shared/**/*.ts\" \"src/config/**/*.ts\" \"src/firebaseApp.ts\"",
    "lint:deploy:all": "eslint -c eslint.config.js \"src/**/*.ts\"",
    "lint:fix:chat": "eslint -c eslint.config.js \"src/chat/**/*.ts\" --fix",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "npm run build && node --test lib/account_lifecycle/interaction-access.policy.test.js lib/community/community-feed-access.policy.test.js lib/community/community-feed.model.test.js lib/community/community-membership-eligibility.service.test.js lib/community/community-membership-request.policy.test.js lib/community/community-preview.model.test.js lib/community/community-user-index.projection.test.js lib/community/create-community.model.test.js lib/community/create-venue-community.model.test.js lib/compliance/profile-age-reverification.policy.test.js lib/media/application/sync-published-photo-on-private-update.use-case.test.js lib/media/application/video-publication-settings.test.js lib/media/application/media-engagement-score.test.js lib/media/application/video-processing-invalid-source.test.js lib/media/application/video-rating-aggregate.test.js lib/media/application/video-report-safety.test.js lib/media/application/video-view-qualification.test.js lib/payments/application/platform-subscription-entitlement.service.test.js lib/subscriber-experiences/exclusive-connections/exclusive-connections-access.policy.test.js lib/subscriber-experiences/exclusive-connections/exclusive-connections.model.test.js",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "audit:prod": "npm audit --omit=dev",
    "audit:all": "npm audit"
  },
  "dependencies": {
    "axios": "^1.13.1",
    "busboy": "^1.6.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.2.5",
    "form-data": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/busboy": "^1.5.4",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^9.39.4",
    "firebase-functions-test": "^3.4.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
