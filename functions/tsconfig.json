{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Node20",
    "moduleResolution": "node16",
    "lib": ["ES2023"],
    "outDir": "lib",
    "rootDir": "src",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "compileOnSave": true,
  "include": [
    "src",
    "types",
    "src/**/*"
  ]
}
